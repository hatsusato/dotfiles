# ~/.bashrc — Git Bash for Windows (MSYS2) shell configuration
# Sourced for interactive non-login shells.

# Prompt (indicates Git Bash context)
PS1='[GitBash] \u@\h:\w\$ '

# Aliases
alias ll='ls -la'
alias la='ls -A'

# Scoop shims (if scoop installed)
# export PATH="$USERPROFILE/scoop/shims:$PATH"

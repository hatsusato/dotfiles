#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import hashlib
import json
import os
import shutil
import subprocess
import sys
import tarfile
from argparse import ArgumentParser, RawDescriptionHelpFormatter
from contextlib import contextmanager
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from tempfile import NamedTemporaryFile
from typing import Literal, Self


class TrashPath(Path):
    """Path subclass with type detection and validation.

    Validates path at creation time: checks existence, detects type,
    prevents dangerous paths. Inherits from Path for transparent API access.
    """

    @classmethod
    def create(cls, path: Path | str) -> Self:
        """Validate and create TrashPath.

        Encapsulates path normalization, existence checking, and dangerous path
        detection. All validation logic is centralized here.

        Args:
            path: Relative or absolute file path

        Returns:
            TrashPath instance (a Path subclass)

        Raises:
            FileNotFoundError: Path does not exist and is not a symlink
            ValueError: Path is a dangerous system directory under cwd
        """
        # Normalize path to absolute
        absolute_path = Path(path).absolute()
        resolved = absolute_path.parent.resolve() / absolute_path.name
        # Check existence (symlinks may point to nonexistent targets — check both)
        if not resolved.exists() and not resolved.is_symlink():
            raise FileNotFoundError(f"{path}: No such file or directory")
        # Reject if resolved is ancestor of cwd (system directory)
        if Path.cwd().is_relative_to(resolved):
            raise ValueError(f"Cannot trash system directory: {path}")
        # Create Path instance
        return cls(resolved)


class Metadata:
    """Record of a trashed item: hash, original path, type, date.

    Pure data container — stores validated path, hash, type, and date.
    """

    def __init__(
        self,
        hash: str,
        path: str,
        type: Literal["file", "dir", "symlink"],
        date: str = "",
    ) -> None:
        """Initialize Metadata with hash, path, type, and optional date.

        Args:
            hash: SHA256 hash hexdigest of item content or symlink target
            path: Original path of the trashed item (as string)
            type: Type of item ("file", "dir", or "symlink")
            date: Optional ISO8601 timestamp; defaults to current time if omitted
        """
        self.hash = hash
        self.path = path
        self.type = type
        self.date = date if date else self.now()

    def to_dict(self) -> dict[str, str]:
        """Convert to JSON-serializable dict."""
        return dict(hash=self.hash, path=self.path, type=self.type, date=self.date)

    @classmethod
    def from_dict(cls, d: dict[str, str]) -> Self:
        """Deserialize from JSON dict."""
        if d["type"] not in ("file", "dir", "symlink"):
            raise ValueError(f"Invalid type in metadata: {d['type']}")
        return cls(hash=d["hash"], path=d["path"], type=d["type"], date=d["date"])

    @staticmethod
    def now() -> str:
        """Return current timestamp in ISO8601 UTC format.

        Returns:
            ISO8601 formatted timestamp string (YYYY-MM-DDTHH:MM:SS)
        """
        return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S")


@dataclass
class TrashConfig:
    """Immutable configuration for trash operations.

    Dataclass enforces field ordering: verbose, force, recursive must be
    provided by caller; trash_dir defaults to TrashDir() which reads TRASH_DIR
    environment variable at instantiation time.
    """

    verbose: bool
    force: bool
    recursive: bool
    # Default: read TRASH_DIR env var or ~/.trash
    trash_dir_path = Path(os.getenv("TRASH_DIR", Path.home() / ".trash"))

    def get_trash_path(self, hash_value: str) -> Path:
        """Get final trash path for given hash.

        Ensures trash directory and its parents exist, then returns the
        path to the trashed item (trash_dir/{hash_value}).

        Args:
            hash_value: SHA256 hash hexdigest of item content or symlink target

        Returns:
            Path to the trashed item in trash_dir
        """
        trash_path = self.trash_dir_path / hash_value
        trash_path.parent.mkdir(parents=True, exist_ok=True)
        return trash_path

    @contextmanager
    def get_temp_file(self, prefix: str | None = None, suffix: str | None = None):
        """Context manager for creating a temporary file in trash_dir.

        Creates NamedTemporaryFile with delete=False, so caller must delete it
        explicitly. If an exception occurs, file is deleted automatically.

        Args:
            prefix: Optional prefix for temp file name
            suffix: Optional suffix for temp file name (e.g., ".tar")

        Yields:
            NamedTemporaryFile instance (already created and open)
        """
        tmp = NamedTemporaryFile(
            delete=False, dir=self.trash_dir_path, prefix=prefix, suffix=suffix
        )
        success = False
        try:
            yield tmp
            success = True
        finally:
            tmp.close()
            if not success:
                os.unlink(tmp.name)

    def write_metadata(self, metadata: Metadata) -> None:
        """Append this metadata entry to metadata.jsonl in JSON Lines format.

        Each line is a complete JSON object representing one trashed item.
        Uses ensure_ascii=False to preserve original characters; separators
        to minimize output size.

        Args:
            metadata: Metadata entry to write
        """
        metadata_path = self.trash_dir_path / "metadata.jsonl"
        metadata_path.parent.mkdir(parents=True, exist_ok=True)
        with open(metadata_path, "a") as f:
            json.dump(metadata.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")

    def trash_symlink(self, path: TrashPath) -> Metadata:
        """Trash a symlink by hashing its target and moving it to trash.

        Hash is computed from symlink target string. Returns Metadata with hash set.

        Args:
            path: Path to symlink

        Returns:
            Metadata with hash and type set

        Raises:
            RuntimeError: If symlink cannot be trashed
        """
        hash_value = _hash_str(str(path.readlink()))
        trash_path = self.get_trash_path(hash_value)
        shutil.move(path, trash_path)
        return Metadata(hash=hash_value, path=str(path), type="symlink")

    def trash_dir(self, path: TrashPath) -> Metadata:
        """Trash a directory by creating a tar of its contents and moving it to trash.

        Returns Metadata with hash set.

        Args:
            path: Path to directory

        Returns:
            Metadata with hash and type set

        Raises:
            RuntimeError: If directory cannot be trashed
        """
        # Check -r guard (permission-aware guard, not validation)
        if not self.recursive:
            raise ValueError("Cannot trash directory without -r flag")
        with self.get_temp_file(suffix=".tar") as tmp:
            cmd = ["tar", "-cf", tmp.name, "-C", str(path), "."]
            subprocess.run(cmd, check=True)
            tar_path = Path(tmp.name)
        hash_value = _hash_file(tar_path)
        trash_path = self.get_trash_path(hash_value)
        tar_path.rename(trash_path)
        shutil.rmtree(path)
        return Metadata(hash=hash_value, path=str(path), type="dir")

    def trash_file(self, path: TrashPath) -> Metadata:
        """Trash a regular file by hashing it and moving it to trash.

        Returns Metadata with hash set.

        Args:
            path: Path to file

        Returns:
            Metadata with hash and type set

        Raises:
            RuntimeError: If file cannot be trashed
        """
        hash_value = _hash_file(path)
        trash_path = self.get_trash_path(hash_value)
        shutil.move(path, trash_path)
        return Metadata(hash=hash_value, path=str(path), type="file")


@dataclass
class RestoreConfig:
    """Configuration for restore operations.

    Reads TRASH_DIR environment variable at instantiation time;
    falls back to ~/.trash if not set.
    """

    verbose: bool = False
    trash_dir_path: Path = None

    def __post_init__(self):
        if self.trash_dir_path is None:
            self.trash_dir_path = Path(
                os.getenv("TRASH_DIR", str(Path.home() / ".trash"))
            )

    @property
    def metadata_path(self) -> Path:
        """Return path to metadata.jsonl inside trash_dir."""
        return self.trash_dir_path / "metadata.jsonl"

    def get_trash_path(self, hash_value: str) -> Path:
        """Return path to trashed item by hash.

        Args:
            hash_value: SHA256 hash hexdigest of the item

        Returns:
            Path to the item in trash_dir
        """
        return self.trash_dir_path / hash_value

    def write_metadata(self, metadata: Metadata) -> None:
        """Append a metadata entry to metadata.jsonl.

        Args:
            metadata: Metadata entry to append
        """
        self.metadata_path.parent.mkdir(parents=True, exist_ok=True)
        with open(self.metadata_path, "a") as f:
            json.dump(metadata.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")

    def list_trash(self) -> None:
        """Print metadata.jsonl contents in human-readable format to stdout.

        Displays numbered list with path, hash, type, and date for each entry.
        Prints nothing (empty output) if trash is empty or metadata.jsonl missing.
        """
        if not self.metadata_path.exists():
            return
        entries: list[Metadata] = []
        with open(self.metadata_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = Metadata.from_dict(json.loads(line))
                    entries.append(entry)
                except (ValueError, KeyError) as e:
                    print(
                        f"trash: warning: skipping malformed entry: {e}",
                        file=sys.stderr,
                    )
        if not entries:
            return
        print(f"Files in trash ({len(entries)}):")
        for i, entry in enumerate(entries, 1):
            print(f"  {i}. {entry.path}")
            print(f"     hash: {entry.hash}")
            print(f"     type: {entry.type}")
            print(f"     date: {entry.date}")


def _read_metadata_entries(metadata_path: Path) -> list[Metadata]:
    """Read and parse all metadata entries from metadata.jsonl.

    Args:
        metadata_path: Path to metadata.jsonl

    Returns:
        List of Metadata objects (empty if file missing or empty)

    Raises:
        ValueError: If a line contains malformed JSON or invalid type
    """
    entries: list[Metadata] = []
    if not metadata_path.exists():
        return entries
    with open(metadata_path) as f:
        for lineno, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue
            try:
                entry = Metadata.from_dict(json.loads(line))
                entries.append(entry)
            except (json.JSONDecodeError, KeyError, ValueError) as e:
                raise ValueError(
                    f"Malformed metadata entry at line {lineno}: {e}"
                ) from e
    return entries


def _remove_metadata_entry(
    metadata_path: Path, target_path: str, target_hash: str
) -> None:
    """Remove the specific metadata entry matching path AND hash from metadata.jsonl.

    Removes only the first entry whose path and hash both match, leaving any
    other entries for the same path (e.g. a backup written during conflict
    handling) intact.

    Args:
        metadata_path: Path to metadata.jsonl
        target_path: Absolute canonical path string to match
        target_hash: SHA256 hash hexdigest to match (prevents removing backup entries)
    """
    if not metadata_path.exists():
        return
    remaining: list[dict[str, str]] = []
    removed = False
    with open(metadata_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entry_dict = json.loads(line)
                # Remove only the first entry matching both path and hash
                if (
                    not removed
                    and entry_dict.get("path") == target_path
                    and entry_dict.get("hash") == target_hash
                ):
                    removed = True
                else:
                    remaining.append(entry_dict)
            except json.JSONDecodeError:
                # Preserve malformed lines rather than silently dropping them
                pass
    with open(metadata_path, "w") as f:
        for entry_dict in remaining:
            json.dump(entry_dict, f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")


def _backup_existing_to_trash(path: Path, config: RestoreConfig) -> None:
    """Move an existing file/dir/symlink to trash before restoring over it.

    Called when restore target already exists. The existing item is backed up
    to trash with its own metadata entry to prevent data loss.

    Args:
        path: Path to the existing item to back up
        config: RestoreConfig with trash_dir_path
    """
    print(
        f"trash: {path} exists; backing up to trash...",
        file=sys.stderr,
    )
    if path.is_symlink():
        # Hash from symlink target string (mirrors trash_symlink)
        hash_value = _hash_str(str(path.readlink()))
        item_type: Literal["file", "dir", "symlink"] = "symlink"
    elif path.is_dir():
        # Hash directory via tar (mirrors trash_dir)
        with NamedTemporaryFile(
            delete=False, dir=config.trash_dir_path, suffix=".tar"
        ) as tmp:
            tmp_path = Path(tmp.name)
        try:
            subprocess.run(
                ["tar", "-cf", str(tmp_path), "-C", str(path), "."],
                check=True,
            )
            hash_value = _hash_file(tmp_path)
            item_type = "dir"
            backup_path = config.get_trash_path(hash_value)
            tmp_path.rename(backup_path)
            shutil.rmtree(path)
        except Exception:
            if tmp_path.exists():
                os.unlink(tmp_path)
            raise
        metadata = Metadata(hash=hash_value, path=str(path), type=item_type)
        config.write_metadata(metadata)
        return
    else:
        # Regular file
        hash_value = _hash_file(path)
        item_type = "file"

    backup_path = config.get_trash_path(hash_value)
    shutil.move(str(path), backup_path)
    metadata = Metadata(hash=hash_value, path=str(path), type=item_type)
    config.write_metadata(metadata)


def _restore_file(target_path: Path, metadata: Metadata, config: RestoreConfig) -> None:
    """Move a regular file from trash back to target_path.

    Backs up any existing file at target_path before restoring.

    Args:
        target_path: Destination path for the restored file
        metadata: Metadata entry with hash
        config: RestoreConfig with trash_dir_path

    Raises:
        FileNotFoundError: If the trash file is missing
    """
    trash_path = config.get_trash_path(metadata.hash)
    if not trash_path.exists():
        raise FileNotFoundError(
            f"Trash file missing: {trash_path} (hash: {metadata.hash})"
        )
    # Back up any existing file at target before restoring
    if target_path.exists() or target_path.is_symlink():
        _backup_existing_to_trash(target_path, config)
    target_path.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(trash_path), target_path)


def _restore_dir(target_path: Path, metadata: Metadata, config: RestoreConfig) -> None:
    """Extract a tar archive from trash back to target_path as a directory.

    Uses tarfile.extractall(filter="data") to prevent Zip Slip attacks.
    Backs up any existing directory at target_path before restoring.

    Args:
        target_path: Destination directory path for the restored directory
        metadata: Metadata entry with hash
        config: RestoreConfig with trash_dir_path

    Raises:
        FileNotFoundError: If the tar archive is missing
    """
    tar_path = config.get_trash_path(metadata.hash)
    if not tar_path.exists():
        raise FileNotFoundError(
            f"Tar archive missing: {tar_path} (hash: {metadata.hash})"
        )
    # Back up any existing directory at target before restoring
    if target_path.exists() or target_path.is_symlink():
        _backup_existing_to_trash(target_path, config)
    target_path.parent.mkdir(parents=True, exist_ok=True)
    target_path.mkdir(exist_ok=True)
    with tarfile.open(tar_path) as tf:
        # filter="data" prevents Zip Slip: rejects symlinks outside extraction dir
        tf.extractall(target_path, filter="data")
    # Remove tar from trash after successful extraction
    tar_path.unlink()


def _restore_symlink(
    target_path: Path, metadata: Metadata, config: RestoreConfig
) -> None:
    """Move a symlink from trash back to target_path.

    Backs up any existing file/symlink at target_path before restoring.

    Args:
        target_path: Destination path for the restored symlink
        metadata: Metadata entry with hash
        config: RestoreConfig with trash_dir_path

    Raises:
        FileNotFoundError: If the trash symlink is missing
    """
    trash_path = config.get_trash_path(metadata.hash)
    if not trash_path.exists() and not trash_path.is_symlink():
        raise FileNotFoundError(
            f"Trash symlink missing: {trash_path} (hash: {metadata.hash})"
        )
    # Back up any existing item at target before restoring
    if target_path.exists() or target_path.is_symlink():
        _backup_existing_to_trash(target_path, config)
    target_path.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(trash_path), target_path)


def _restore_by_path(path: str, config: RestoreConfig) -> bool:
    """Restore a single file/dir/symlink from trash by its original path.

    Searches metadata.jsonl for an entry matching the resolved absolute path,
    dispatches to the appropriate type-specific restore function, then removes
    the metadata entry on success.

    Security: Always resolves user-provided path to absolute canonical form
    via Path.resolve() before comparing against metadata (prevents path traversal).

    Args:
        path: User-provided path (relative or absolute) to restore
        config: RestoreConfig with trash_dir_path

    Returns:
        True on success

    Raises:
        ValueError: If no metadata entry matches the resolved path
        FileNotFoundError: If trash file/archive is missing
    """
    # Resolve to absolute canonical path (handles .., symlinks, relative paths)
    target_path = Path(path).resolve()

    entries = _read_metadata_entries(config.metadata_path)
    metadata_entry: Metadata | None = None
    for entry in entries:
        if entry.path == str(target_path):
            metadata_entry = entry
            break

    if metadata_entry is None:
        raise ValueError(f"No trash entry found for {path} (resolved: {target_path})")

    if config.verbose:
        print(
            f"trash: restoring {target_path} [hash: {metadata_entry.hash}]",
            file=sys.stderr,
        )

    if metadata_entry.type == "file":
        _restore_file(target_path, metadata_entry, config)
    elif metadata_entry.type == "dir":
        _restore_dir(target_path, metadata_entry, config)
    elif metadata_entry.type == "symlink":
        _restore_symlink(target_path, metadata_entry, config)

    # Remove the metadata entry after successful restore (match by path + hash)
    _remove_metadata_entry(config.metadata_path, str(target_path), metadata_entry.hash)

    if config.verbose:
        print(f"trash: restored {target_path}", file=sys.stderr)

    return True


def _hash_str(s: str) -> str:
    """Compute SHA256 hash of a string.

    Pure function for hashing strings. Takes explicit string parameter,
    returns computed hash string. No state mutation.

    Args:
        s: Input string to hash

    Returns:
        SHA256 hexdigest as string
    """
    return hashlib.sha256(s.encode()).hexdigest()


def _hash_file(file_path: Path) -> str:
    """Compute SHA256 hash of file in 8KB chunks.

    Pure function for hashing files. Takes explicit path parameter,
    returns computed hash string. No state mutation.

    Args:
        file_path: Path to file to hash

    Returns:
        SHA256 hexdigest as string

    Raises:
        RuntimeError: If file cannot be read
    """
    sha256 = hashlib.sha256()
    try:
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                sha256.update(chunk)
        return sha256.hexdigest()
    except (FileNotFoundError, PermissionError, IOError) as e:
        raise RuntimeError(f"Failed to hash file: {e}") from e


def _setup_parser() -> ArgumentParser:
    """Set up and parse command-line arguments.

    Returns:
        ArgumentParser instance with configured arguments and help text
    """
    epilog = [
        "Examples:",
        "  trash file1.txt",
        "  trash file1 file2 directory/",
        "  trash -r important_dir/",
        "  trash -v -r backup.tar.gz",
        "  trash -f old_nonexistent_file",
        "  trash --restore /path/to/file",
        "  trash --list",
        "",
        "Note: Files are moved to ~/.trash for recovery.",
    ]
    parser = ArgumentParser(
        prog="trash",
        description="Safe deletion and recovery via backup location (~/.trash)",
        epilog=("\n".join(epilog)),
        formatter_class=RawDescriptionHelpFormatter,
        add_help=True,
    )
    parser.add_argument(
        "--restore",
        action="store_true",
        help="Restore file(s) from trash by their original path",
    )
    parser.add_argument(
        "--list",
        "-l",
        action="store_true",
        help="List all items in trash",
    )
    parser.add_argument(
        "-r",
        "--recursive",
        action="store_true",
        help="Required for directories (compress with tar)",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true", help="Show hashes for trashed items"
    )
    parser.add_argument(
        "-f", "--force", action="store_true", help="Ignore nonexistent files"
    )
    parser.add_argument(
        "files",
        nargs="*",
        type=Path,
        help="Files or directories to trash (or paths to restore with --restore)",
    )
    return parser


def _process_files(file_paths: list[Path], config: TrashConfig) -> bool:
    """Process multiple files by trashing them and recording metadata.

    Iterates over file paths, calls _process_file_path for each, and tracks
    overall success. Returns True if all files processed successfully, False
    if any errors occurred (unless force flag is set).

    Args:
        file_paths: List of paths to files or directories
        config: Trash configuration

    Returns:
        True if all files processed successfully, False if any errors occurred
    """
    success = True
    for file_path in file_paths:
        try:
            trash_path = TrashPath.create(file_path)
            if trash_path.is_symlink():
                metadata = config.trash_symlink(trash_path)
            elif trash_path.is_dir():
                metadata = config.trash_dir(trash_path)
            else:
                metadata = config.trash_file(trash_path)
            config.write_metadata(metadata)
            if config.verbose:
                print(
                    f"Trashed: {file_path} [hash: {metadata.hash}]",
                    file=sys.stderr,
                )
        except FileNotFoundError:
            if config.force:
                # force flag: silently skip nonexistent files
                continue
            print(
                f"Error trashing {file_path}: No such file or directory",
                file=sys.stderr,
            )
            success = False
        except (ValueError, RuntimeError) as e:
            print(f"Error trashing {file_path}: {e}", file=sys.stderr)
            success = False
    return success


EXIT_SUCCESS = 0
EXIT_FAILURE = 1


def main() -> int:
    """Main entry point: orchestrate trash, restore, or list operations.

    Parses command-line arguments and dispatches to trash, restore, or list
    operations based on flags.
    """
    parser = _setup_parser()
    args = parser.parse_args()

    # Handle --list (shows all items in trash)
    if args.list:
        restore_config = RestoreConfig(verbose=args.verbose)
        restore_config.list_trash()
        return EXIT_SUCCESS

    # Handle --restore (restore files from trash)
    if args.restore:
        if not args.files:
            print("Error: provide a path to restore or use --list", file=sys.stderr)
            parser.print_help(sys.stderr)
            return EXIT_FAILURE
        restore_config = RestoreConfig(verbose=args.verbose)
        success = True
        for path in args.files:
            try:
                _restore_by_path(str(path), restore_config)
            except (ValueError, FileNotFoundError) as e:
                print(f"trash: error: {e}", file=sys.stderr)
                success = False
            except Exception as e:
                print(f"trash: unexpected error: {e}", file=sys.stderr)
                success = False
        return EXIT_SUCCESS if success else EXIT_FAILURE

    # Handle normal trash operation
    if not args.files:
        print("Error: Missing file arguments", file=sys.stderr)
        parser.print_help(sys.stderr)
        return EXIT_FAILURE

    # Build TrashConfig once after args parse
    config = TrashConfig(
        verbose=args.verbose,
        force=args.force,
        recursive=args.recursive,
    )
    # Process each file
    if _process_files(args.files, config):
        return EXIT_SUCCESS
    else:
        return EXIT_FAILURE


if __name__ == "__main__":
    sys.exit(main())

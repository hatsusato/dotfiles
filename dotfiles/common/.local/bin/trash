#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import bisect
import json
import os
import shutil
import sys
import time
from argparse import ArgumentParser, Namespace, RawDescriptionHelpFormatter
from dataclasses import dataclass
from dataclasses import replace as dataclass_replace
from datetime import datetime
from json import JSONDecodeError
from pathlib import Path
from shutil import Error as ShutilError
from typing import Any, Iterator, Self


class TrashPath(Path):
    """Absolute, normalized path for trash operations.

    Always represents an absolute path: TrashPath(relative) is resolved
    against cwd at construction time. Parent directory symlinks are resolved
    via parent.resolve(), but the filename's own symlink is preserved.
    """

    def __init__(self, *args: Any, **kwargs: Any) -> None:
        raw = Path(*args)
        abs_path = raw.absolute()
        normalized = abs_path.parent.resolve() / abs_path.name
        super().__init__(str(normalized))


@dataclass
class TrashEvent:
    """Single event in trash-log.jsonl."""

    path: TrashPath
    timestamp: int = 0  # Epoch nanoseconds when trashed (= filename in .trash/)
    restore: bool = False

    def _to_dict(self) -> dict[str, str | int | bool]:
        """Convert to JSON-serializable dict (internal use)."""
        return {
            "path": str(self.path),
            "timestamp": self.timestamp,
            "restore": self.restore,
        }

    @classmethod
    def _from_dict(cls, d: dict[str, str | int | bool]) -> Self:
        """Deserialize from JSON dict (internal use)."""
        return cls(
            path=TrashPath(str(d["path"])),
            timestamp=int(d["timestamp"]),
            restore=bool(d.get("restore", False)),
        )

    def to_line(self) -> str:
        """Serialize to JSONL line (public API)."""
        return (
            json.dumps(self._to_dict(), ensure_ascii=False, separators=(",", ":"))
            + "\n"
        )

    @classmethod
    def from_line(cls, line: str) -> Self:
        """Deserialize from JSONL line (public API)."""
        return cls._from_dict(json.loads(line))

    def format_timestamp(self) -> str:
        """Convert nanosecond timestamp to human-readable ISO 8601 string."""
        dt = datetime.fromtimestamp(self.timestamp / 1_000_000_000).astimezone()
        return dt.isoformat(timespec="seconds")

    def as_restore_event(self) -> Self:
        """Create a new TrashEvent for the same path with restore=True."""
        return dataclass_replace(self, restore=True)

    def as_backup_event(self) -> Self:
        """Create a new TrashEvent for the same path with a new timestamp.

        Used for backup operations when restoring to an existing path.
        """
        return dataclass_replace(self, timestamp=0, restore=False)


class TrashEventMap:
    """Manages dict[TrashPath, list[TrashEvent]] with sorted append.

    append() maintains sort order via bisect.insort.
    get_latest_trash_event() returns events[-1] in O(1).
    active_events() iterates over currently-trashed events.
    """

    def __init__(self) -> None:
        self._events: dict[TrashPath, list[TrashEvent]] = {}

    def append(self, event: TrashEvent) -> None:
        """Insert event maintaining sort order by (timestamp, restore)."""
        if event.path not in self._events:
            self._events[event.path] = []
        bisect.insort(
            self._events[event.path],
            event,
            key=lambda e: (e.timestamp, e.restore),
        )

    def get_latest_trash_event(self, path: TrashPath) -> TrashEvent:
        """Get latest non-restore TrashEvent for path in O(1)."""
        events_for_path = self._events.get(path, [])
        if not events_for_path:
            raise ValueError(f"No trash entry found for {path}")
        latest_event = events_for_path[-1]
        if latest_event.restore:
            raise ValueError(
                f"No trash entry found for {path}: most recent entry is a restore event"
            )
        return latest_event

    def active_events(self) -> Iterator[TrashEvent]:
        """Return currently-trashed events (latest per path is not a restore event)."""
        for path in self._events:
            try:
                yield self.get_latest_trash_event(path)
            except ValueError:
                continue


class TrashLog:
    """Manages trash-log.jsonl as append-only event log.

    Call load() before querying events (active_events, get_latest_trash_event).
    Stores events in a TrashEventMap for sorted append and O(1) latest lookup.
    Provides active_events(), get_latest_trash_event(), get_trash_path(),
    execute_event(), and append_event().
    """

    def __init__(self) -> None:
        """Initialize TrashLog; defaults to TRASH_DIR env or ~/.trash."""
        self._trash_dir = Path(os.getenv("TRASH_DIR", Path.home() / ".trash"))
        self._metadata_path = self._trash_dir / "trash-log.jsonl"
        self._event_map: TrashEventMap = TrashEventMap()

    def get_latest_trash_event(self, path: TrashPath) -> TrashEvent:
        """Get the latest non-restore TrashEvent for a given path."""
        return self._event_map.get_latest_trash_event(path)

    def get_trash_path(self, event: TrashEvent) -> Path:
        """Return unique path in trash_dir for event; mutates event.timestamp.

        Side effect: event.timestamp is updated to the selected timestamp value.
        Callers must read event.timestamp after this call to get the final value
        (e.g., for verbose output).

        For trash events: increments timestamp until a free slot is found.
        For restore events: returns the path of the already-trashed item.
        """
        if event.timestamp == 0:
            event.timestamp = time.time_ns()
        while True:
            trash_path = self._trash_dir / str(event.timestamp)
            if event.restore or not os.path.lexists(trash_path):
                return trash_path
            event.timestamp += 1

    def _execute_check(self, event: TrashEvent, recursive: bool) -> tuple[Path, Path]:
        """Check preconditions for executing event; return (source_path, target_path).

        For trash events: source_path is event.path, target_path is
        get_trash_path(event).
        For restore events: source_path is get_trash_path(event), target_path is
        event.path.

        Raises FileNotFoundError if source does not exist.
        Raises ValueError for invalid operations (e.g., trashing non-recursive dir).
        """
        if event.restore:
            source_path = self.get_trash_path(event)
            if not os.path.lexists(source_path):
                raise FileNotFoundError(
                    f"Trash item missing (log/filesystem desync): {source_path}"
                )
            return source_path, event.path
        else:
            source_path = event.path
            if not os.path.lexists(source_path):
                raise FileNotFoundError(f"No such file or directory: {source_path}")
            if source_path.is_dir() and not recursive:
                raise ValueError(
                    f"Cannot trash directory without -r flag: {source_path}"
                )
            if Path.cwd().is_relative_to(source_path):
                raise ValueError(f"Cannot trash parent directory: {source_path}")
            return source_path, self.get_trash_path(event)

    def execute_event(self, event: TrashEvent, recursive: bool) -> None:
        """Execute the given TrashEvent, dispatching to trash or restore as needed."""
        source_path, target_path = self._execute_check(event, recursive)
        if event.restore:
            if os.path.lexists(target_path):
                print(
                    f"trash: {target_path} exists; backing up to trash...",
                    file=sys.stderr,
                )
                self.execute_event(event.as_backup_event(), True)
        target_path.parent.mkdir(parents=True, exist_ok=True)
        shutil.move(source_path, target_path)
        self.append_event(event)

    def load(self) -> None:
        """Read and parse trash-log.jsonl, rebuild in-memory event dict.

        Handles missing file, empty file gracefully.
        Tolerates a single truncated final line (crash-during-write pattern).
        Raises ValueError on malformed lines that are not at end-of-file.

        Note: Changes to _event_map must be persisted via append_event().
        """
        self._event_map = TrashEventMap()
        self._trash_dir.mkdir(parents=True, exist_ok=True)
        if not self._metadata_path.exists():
            return
        with open(self._metadata_path) as f:
            raw_lines = f.readlines()
        total_lines = len(raw_lines)
        for lineno, line in enumerate(raw_lines, 1):
            line = line.strip()
            if not line:
                continue
            try:
                event = TrashEvent.from_line(line)
                self._event_map.append(event)
            except (JSONDecodeError, KeyError, ValueError) as e:
                # Tolerate truncated final line only (crash leaves no trailing newline).
                # A complete line ending with "\n" is not crash residue — always raise.
                if lineno == total_lines and not raw_lines[-1].endswith("\n"):
                    break
                raise ValueError(
                    f"Malformed metadata entry at line {lineno}: {e}"
                ) from e

    def active_events(self) -> Iterator[TrashEvent]:
        """Return currently-trashed events (latest per path is not a restore event).

        Uses timestamp-based filtering (max timestamp per path), independent of
        append order. Each path's latest event is checked for restore=False.
        """
        return self._event_map.active_events()

    def append_event(self, event: TrashEvent) -> None:
        """Add event to memory and sync to disk immediately."""
        with open(self._metadata_path, "a") as f:
            f.write(event.to_line())
            os.fsync(f.fileno())
        self._event_map.append(event)


class TrashConfig(Namespace):
    """Configuration for trash operations — argparse Namespace subclass.

    Hides ArgumentParser as internal state. External callers use only:
    - TrashConfig.parse_args(args=None) -> TrashConfig
    - config.print_help()
    """

    verbose: bool
    force: bool
    recursive: bool
    files: list[Path]
    restore: bool
    show_list: bool

    @classmethod
    def _build_parser(cls) -> ArgumentParser:
        """Internal: construct and return ArgumentParser.

        Contains all parser configuration for the trash command.
        Must not be called directly from outside TrashConfig.
        """
        epilog = [
            "Examples:",
            "  trash file1.txt",
            "  trash file1 file2",
            "  trash -r important_dir/",
            "  trash -v -r backup.tar.gz",
            "  trash -f old_nonexistent_file",
            "  trash --restore /path/to/file",
            "  trash --list",
            "",
            "Note: Files are moved to ~/.trash for recovery.",
        ]
        parser = ArgumentParser(
            prog="trash",
            description="Safe deletion and recovery via backup location (~/.trash)",
            epilog=("\n".join(epilog)),
            formatter_class=RawDescriptionHelpFormatter,
            add_help=True,
        )
        parser.add_argument(
            "--restore",
            action="store_true",
            help="Restore file(s) from trash by their original path",
        )
        parser.add_argument(
            "--list",
            "-l",
            action="store_true",
            dest="show_list",
            help="List all items in trash",
        )
        parser.add_argument(
            "-r",
            "--recursive",
            action="store_true",
            help="Required for directories",
        )
        parser.add_argument(
            "-v",
            "--verbose",
            action="store_true",
            help="Show timestamps for trashed items",
        )
        parser.add_argument(
            "-f", "--force", action="store_true", help="Ignore nonexistent files"
        )
        parser.add_argument(
            "files",
            nargs="*",
            type=Path,
            help="Files or directories to trash (or paths to restore with --restore)",
        )
        return parser

    @classmethod
    def parse_args(cls, args: list[str] | None = None) -> Self:
        """Parse CLI arguments into TrashConfig instance.

        Hides ArgumentParser internals. Returns populated TrashConfig.
        """
        parser = cls._build_parser()
        return parser.parse_args(args, namespace=cls())

    def print_help(self) -> None:
        """Print help text to stdout."""
        self._build_parser().print_help()


EXIT_SUCCESS = 0
EXIT_FAILURE = 1
_LIST_START_INDEX = 1  # 1-based display numbering for --list output


def list_items(trash_log: TrashLog) -> None:
    """Print trash-log.jsonl contents in human-readable format to stdout."""
    entries = list(trash_log.active_events())
    if not entries:
        return
    print(f"Files in trash ({len(entries)}):")
    for i, entry in enumerate(entries, _LIST_START_INDEX):
        print(f"  {i}. {entry.path}")
        print(f"     timestamp: {entry.format_timestamp()}")


def main() -> int:
    """Main entry point: orchestrate trash, restore, or list operations.

    Uses get_latest_trash_event().as_restore_event() for restore operations
    (raises ValueError if not found).
    Catches ValueError alongside ShutilError and OSError.
    """
    config = TrashConfig.parse_args()
    trash_log = TrashLog()
    trash_log.load()  # Ensure we have the latest state before operations
    success = EXIT_SUCCESS
    if config.show_list:
        list_items(trash_log)
        return EXIT_SUCCESS
    if not config.files:
        if config.restore:
            msg = "provide a path to restore or use --list"
        else:
            msg = "Missing file arguments"
        print(f"Error: {msg}", file=sys.stderr)
        config.print_help()
        return EXIT_FAILURE
    for path in config.files:
        try:
            trash_path = TrashPath(path)
            if config.restore:
                event = trash_log.get_latest_trash_event(trash_path).as_restore_event()
            else:
                event = TrashEvent(path=trash_path)
            trash_log.execute_event(event, config.recursive)
            if config.verbose:
                op = "restored" if config.restore else "trashed"
                print(
                    f"trash: {op} {path} [timestamp: {event.format_timestamp()}]",
                    file=sys.stderr,
                )
        except (ShutilError, OSError, ValueError) as e:
            if config.force:
                continue
            op = "restoring" if config.restore else "trashing"
            print(f"trash: error {op} {path}: {e}", file=sys.stderr)
            success = EXIT_FAILURE
    return success


if __name__ == "__main__":
    sys.exit(main())

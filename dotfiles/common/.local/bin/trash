#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import sys
import argparse
import json
import os
import uuid
from dataclasses import dataclass
from pathlib import Path
from datetime import datetime, timezone
from typing import Literal, Self
import subprocess
import hashlib
import shutil


class TrashDir(Path):
    """Path subclass for trash directory, reads TRASH_DIR environment variable.

    Inherits from Path for transparent access to path methods (exists, mkdir, etc.).
    Reads TRASH_DIR environment variable at instantiation time; allows different
    instances to potentially use different trash directories if env changes.
    """

    def __new__(cls) -> Self:
        """Create TrashDir, reading TRASH_DIR env var.

        Returns:
            TrashDir instance (a Path subclass)
        """
        return super().__new__(cls)

    def __init__(self) -> None:
        """Initialize TrashDir by reading TRASH_DIR environment variable.

        Reads TRASH_DIR env var (defaulting to ~/.trash) and initializes the
        Path subclass with that directory. Called after __new__.
        """
        trash_dir = os.environ.get("TRASH_DIR", str(Path.home() / ".trash"))
        super().__init__(trash_dir)


class TrashPath(Path):
    """Path subclass with type detection and validation.

    Validates path at creation time: checks existence, detects type,
    prevents dangerous paths. Inherits from Path for transparent API access.
    """

    def __new__(cls, path: Path | str) -> Self:
        """Validate and create TrashPath.

        Encapsulates path normalization, existence checking, and dangerous path
        detection. All validation logic is centralized here.

        Args:
            path: Relative or absolute file path

        Returns:
            TrashPath instance (a Path subclass)

        Raises:
            FileNotFoundError: Path does not exist and is not a symlink
            ValueError: Path is a dangerous system directory under cwd
        """
        # Normalize path to absolute
        normalized = Path(path).absolute()
        # Check existence (symlinks may point to nonexistent targets — check both)
        if not normalized.exists() and not normalized.is_symlink():
            raise FileNotFoundError(f"{path}: No such file or directory")
        # Detect dangerous paths: resolve if possible, use normalized if broken symlink
        try:
            resolved = normalized.resolve() if normalized.exists() else normalized
        except (OSError, RuntimeError):
            # Broken symlink or permission error — use normalized
            resolved = normalized
        # Reject if resolved is ancestor of cwd (system directory)
        if Path.cwd().is_relative_to(resolved):
            raise ValueError(f"Cannot trash system directory: {path}")
        # Create Path instance
        return super().__new__(cls, normalized)

    def __init__(self, path: Path | str) -> None:
        """Initialize TrashPath (Path initialization happens in __new__).

        Called after __new__ for compatibility with Path's initialization protocol.
        All validation logic is in __new__; this is a no-op.
        """
        super().__init__(path)

    @property
    def item_type(self) -> Literal["file", "dir", "symlink"]:
        """Detect and return item type (file, directory, or symlink).

        CRITICAL: Check is_symlink() before is_dir() (symlinks may be to
        directories, and is_dir() follows symlinks).

        Returns:
            Literal["file", "dir", "symlink"]: Type of the path
        """
        if self.is_symlink():
            return "symlink"
        elif self.is_dir():
            return "dir"
        else:
            return "file"


def _hash_file(file_path: Path) -> str:
    """Compute SHA256 hash of file in 8KB chunks.

    Pure function for hashing files. Takes explicit path parameter,
    returns computed hash string. No state mutation.

    Args:
        file_path: Path to file to hash

    Returns:
        SHA256 hexdigest as string

    Raises:
        RuntimeError: If file cannot be read
    """
    sha256 = hashlib.sha256()
    try:
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                sha256.update(chunk)
        return sha256.hexdigest()
    except (FileNotFoundError, PermissionError, IOError) as e:
        raise RuntimeError(f"Failed to hash file: {e}") from e


def _tar_and_hash_dir(path: Path, trash_dir: Path) -> tuple[str, Path]:
    """Create tar of directory contents, hash it, return (hash, temp_path).

    Pure function for tarring and hashing directories. Uses trash_dir as temp
    location (D-08: same filesystem, atomic rename). Tar structure: -C dir_path .
    so tar contains ./file1, ./subdir/file2 etc. Original path is preserved in
    metadata — tar only needs contents (D-09).

    Args:
        path: Directory path to tar
        trash_dir: Trash directory (used as temp location)

    Returns:
        Tuple of (hash_value, temp_tar_path)

    Raises:
        RuntimeError: If tar or hashing fails
    """
    temp_tar = trash_dir / f"tmp_{uuid.uuid4().hex[:8]}.tar"
    try:
        subprocess.run(
            ["tar", "-cf", str(temp_tar), "-C", str(path), "."],
            check=True,
            capture_output=True,
            text=False,
        )
        # Hash the tar file
        hash_value = _hash_file(temp_tar)
        return hash_value, temp_tar
    except subprocess.CalledProcessError as e:
        temp_tar.unlink(missing_ok=True)
        raise RuntimeError(f"Failed to tar directory: {e}") from e
    except RuntimeError:
        temp_tar.unlink(missing_ok=True)
        raise


@dataclass
class TrashConfig:
    """Immutable configuration for trash operations."""

    verbose: bool
    force: bool
    recursive: bool
    trash_dir: Path

    def get_trash_path(self, hash_value: str) -> Path:
        """Get final trash path for given hash.

        Ensures trash directory and its parents exist, then returns the
        path to the trashed item (trash_dir/{hash_value}).

        Args:
            hash_value: SHA256 hash hexdigest of item content or symlink target

        Returns:
            Path to the trashed item in trash_dir
        """
        trash_path = self.trash_dir / hash_value
        trash_path.parent.mkdir(parents=True, exist_ok=True)
        return trash_path


class Metadata:
    """Record of a trashed item: hash, original path, type, date.

    Pure data container — stores validated path, hash, type, and date.
    """

    def __init__(
        self,
        path: str,
        type: Literal["file", "dir", "symlink"],
        date: str = "",
        hash: str = "",
    ) -> None:
        """Initialize Metadata with path, type, and optional date and hash.

        Args:
            path: Original path of the trashed item (as string)
            type: Type of item ("file", "dir", or "symlink")
            date: Optional ISO8601 timestamp; defaults to current time if omitted
            hash: Optional SHA256 hash hexdigest; set later if not provided
        """
        self.path = path
        self.type = type
        self.date = date if date else self.now()
        self.hash = hash

    def to_dict(self) -> dict[str, str]:
        """Convert to JSON-serializable dict."""
        return dict(hash=self.hash, path=self.path, type=self.type, date=self.date)

    @classmethod
    def from_dict(cls, d: dict[str, str]) -> Self:
        """Deserialize from JSON dict."""
        if d["type"] not in ("file", "dir", "symlink"):
            raise ValueError(f"Invalid type in metadata: {d['type']}")
        return cls(hash=d["hash"], path=d["path"], type=d["type"], date=d["date"])

    @staticmethod
    def now() -> str:
        """Return current timestamp in ISO8601 UTC format.

        Returns:
            ISO8601 formatted timestamp string (YYYY-MM-DDTHH:MM:SS)
        """
        return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S")

    def write_to_jsonl(self, metadata_path: Path) -> None:
        """Append this metadata entry to metadata.jsonl in JSON Lines format."""
        metadata_path.parent.mkdir(parents=True, exist_ok=True)
        with open(metadata_path, "a") as f:
            json.dump(self.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")


def trash_symlink(path: TrashPath, config: TrashConfig) -> Metadata:
    """Move symlink directly to trash; preserve inode and target path.

    Hash is computed from symlink target string. Returns Metadata with hash set.

    Args:
        path: Path to symlink
        config: Trash configuration

    Returns:
        Metadata with hash and type set

    Raises:
        RuntimeError: If symlink cannot be trashed
    """
    symlink_target = path.readlink()
    hash_value = hashlib.sha256(str(symlink_target).encode()).hexdigest()
    trash_path = config.get_trash_path(hash_value)
    shutil.move(path, trash_path)
    return Metadata(path=str(path), hash=hash_value, type="symlink")


def trash_file(path: TrashPath, config: TrashConfig) -> Metadata:
    """Hash file and move to trash_dir/{hash}.

    Returns Metadata with hash set.

    Args:
        path: Path to file
        config: Trash configuration

    Returns:
        Metadata with hash and type set

    Raises:
        RuntimeError: If file cannot be trashed
    """
    hash_value = _hash_file(path)
    trash_path = config.get_trash_path(hash_value)
    shutil.move(path, trash_path)
    return Metadata(path=str(path), hash=hash_value, type="file")


def trash_dir(path: TrashPath, config: TrashConfig) -> Metadata:
    """Tar directory contents, hash archive, move to trash, record metadata.

    Returns Metadata with hash set.

    Args:
        path: Path to directory
        config: Trash configuration

    Returns:
        Metadata with hash and type set

    Raises:
        RuntimeError: If directory cannot be trashed
    """
    hash_value, tar_path = _tar_and_hash_dir(path, config.trash_dir)
    final_path = config.get_trash_path(hash_value)
    tar_path.rename(final_path)
    shutil.rmtree(path)
    return Metadata(path=str(path), hash=hash_value, type="dir")


def _process_file_path(file_path: Path, config: TrashConfig) -> bool:
    """Process a single file by dispatching to the appropriate trash function.

    Validates path existence, checks type, enforces -r guard for directories,
    dispatches to appropriate handler (trash_symlink, trash_dir, or trash_file),
    and records metadata. Handles exceptions with optional force flag.

    Args:
        file_path: Path to file or directory
        config: Trash configuration

    Returns:
        True if successful, False if error occurred
    """
    try:
        trash_path = TrashPath(file_path)
        # Check -r guard (permission-aware guard, not validation)
        if trash_path.item_type == "dir" and not config.recursive:
            print(
                f"Error trashing {file_path}: Cannot trash directory without -r flag",
                file=sys.stderr,
            )
            return False
        # Dispatch to appropriate function
        if trash_path.item_type == "symlink":
            metadata = trash_symlink(trash_path, config)
        elif trash_path.item_type == "dir":
            metadata = trash_dir(trash_path, config)
        else:
            metadata = trash_file(trash_path, config)
        # Record metadata
        metadata.write_to_jsonl(config.trash_dir / "metadata.jsonl")
        if config.verbose:
            print(
                f"Trashed: {file_path} [hash: {metadata.hash}]",
                file=sys.stderr,
            )
        return True
    except FileNotFoundError:
        if config.force:
            # force flag: silently skip nonexistent files
            return True
        print(
            f"Error trashing {file_path}: No such file or directory",
            file=sys.stderr,
        )
        return False
    except (ValueError, RuntimeError) as e:
        print(f"Error trashing {file_path}: {e}", file=sys.stderr)
        return False


# Constants
DEFAULT_TRASH_DIR = Path.home() / ".trash"
EXIT_SUCCESS = 0
EXIT_FAILURE = 1


def main() -> int:
    """Main entry point: orchestrate trash operations with configuration.

    Parses command-line arguments, validates file arguments, builds TrashConfig,
    and processes each file. Exception handling is delegated to _process_file_path().
    """
    parser = argparse.ArgumentParser(
        prog="trash",
        description="Move files and directories to a backup location (~/.trash)",
        epilog=(
            "\n".join(
                [
                    "Examples:",
                    "  trash file1.txt",
                    "  trash file1 file2 directory/",
                    "  trash -r important_dir/",
                    "  trash -v -r backup.tar.gz",
                    "  trash -f old_nonexistent_file",
                    "",
                    "Note: Files are moved to ~/.trash for recovery.",
                ]
            )
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=True,
    )
    parser.add_argument(
        "-r",
        "--recursive",
        action="store_true",
        help="Required for directories (compress with tar)",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true", help="Show hashes for trashed items"
    )
    parser.add_argument(
        "-f", "--force", action="store_true", help="Ignore nonexistent files"
    )
    parser.add_argument(
        "files", nargs="*", type=Path, help="Files or directories to trash"
    )
    args = parser.parse_args()
    # Check if files provided
    if not args.files:
        print("Error: Missing file arguments", file=sys.stderr)
        parser.print_help(sys.stderr)
        return EXIT_FAILURE
    # Build TrashConfig once after args parse
    trash_dir_path = Path(os.environ.get("TRASH_DIR", DEFAULT_TRASH_DIR))
    config = TrashConfig(
        verbose=args.verbose,
        force=args.force,
        recursive=args.recursive,
        trash_dir=trash_dir_path,
    )
    # Process each file
    success = True
    for file_path in args.files:
        success = _process_file_path(file_path, config) and success
    return EXIT_SUCCESS if success else EXIT_FAILURE


if __name__ == "__main__":
    sys.exit(main())

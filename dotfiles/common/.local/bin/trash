#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import sys
import argparse
import json
import os
import uuid
from abc import ABC, abstractmethod
from dataclasses import dataclass
from pathlib import Path
from datetime import datetime, timezone
import subprocess
import hashlib
import shutil

# Constants
DEFAULT_TRASH_DIR = Path.home() / ".trash"
EXIT_SUCCESS = 0
EXIT_FAILURE = 1


@dataclass
class TrashConfig:
    """Immutable configuration for trash operations."""

    trash_dir: Path
    verbose: bool = False
    force: bool = False
    recursive: bool = False


class Metadata:
    """Record of a trashed item: hash, original path, type, date.

    Metadata objects are created via from_path() factory for validation and
    normalization. The __init__ method assumes preconditions are met and expects
    a valid, normalized path.
    """

    def __init__(
        self, path: Path, hash: str | None = None, item_type: str | None = None
    ) -> None:
        self.path = path
        self.date = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S")
        self.type = item_type if item_type is not None else self._determine_type()
        # Hash is provided by caller for symlinks/files; for directories, hash is set after tar
        if hash is not None:
            self.hash = hash
        elif self.type == "dir":
            # Directory hash is computed after tar creation; leave as None for now
            self.hash = None
        else:
            # Regular file: compute hash
            self.hash = self._hash_file(path)

    def _determine_type(self) -> str:
        """Detect item type. Check is_symlink() BEFORE is_dir() (D-06 pitfall)."""
        if self.path.is_symlink():
            return "symlink"
        if self.path.is_dir():
            return "dir"
        return "file"

    @staticmethod
    def _hash_file(file_path: Path) -> str:
        """Compute SHA256 hash of file in 8KB chunks.

        Raises:
            RuntimeError: If file cannot be read
        """
        sha256 = hashlib.sha256()
        try:
            with open(file_path, "rb") as f:
                for chunk in iter(lambda: f.read(8192), b""):
                    sha256.update(chunk)
            return sha256.hexdigest()
        except (FileNotFoundError, PermissionError, IOError) as e:
            raise RuntimeError(f"Failed to hash file: {e}") from e

    def to_dict(self) -> dict[str, str | None]:
        """Convert to JSON-serializable dict."""
        return {
            "hash": self.hash,
            "path": str(self.path),
            "type": self.type,
            "date": self.date,
        }

    @classmethod
    def from_dict(cls, d: dict[str, str]) -> "Metadata":
        """Deserialize from JSON dict."""
        m = cls(
            path=Path(d["path"]),
            hash=d["hash"],
            item_type=d["type"],
        )
        m.date = d["date"]
        return m

    @classmethod
    def from_path(cls, path: Path) -> "Metadata":
        """Validate filesystem path for trasheability (normalization and safety checks).

        Encapsulates path normalization, existence checking, and dangerous path
        detection. Does NOT compute hash/type — those are determined by TrashItem
        subclasses during trash(). Returns Metadata with normalized path only.

        Args:
            path: Relative or absolute file path

        Returns:
            Metadata instance with normalized path only (hash and type set to None)

        Raises:
            FileNotFoundError: Path does not exist and is not a symlink
            ValueError: Path is a dangerous system directory (/, home, .)
        """
        # Normalize path to absolute
        normalized = path if path.is_absolute() else Path.cwd() / path

        # Check existence (symlinks may point to nonexistent targets — check both)
        if not normalized.exists() and not normalized.is_symlink():
            raise FileNotFoundError(f"{path}: No such file or directory")

        # Detect dangerous paths: resolve if possible, use normalized if broken symlink
        try:
            resolved = normalized.resolve() if normalized.exists() else normalized
        except (OSError, RuntimeError):
            # Broken symlink or permission error — use normalized
            resolved = normalized

        if resolved in (Path("/"), Path.home(), Path(".")):
            raise ValueError(f"Cannot trash system directory: {path}")

        # Return Metadata with normalized path only; hash and type determined by TrashItem.trash()
        return cls(normalized)

    @staticmethod
    def _determine_type_static(path: Path) -> str:
        """Detect item type. Check is_symlink() BEFORE is_dir() (D-06 pitfall).

        This static version is used by from_path() during validation.
        """
        if path.is_symlink():
            return "symlink"
        if path.is_dir():
            return "dir"
        return "file"

    def write_to_jsonl(self, metadata_path: Path) -> None:
        """Append this metadata entry to metadata.jsonl in JSON Lines format."""
        metadata_path.parent.mkdir(parents=True, exist_ok=True)
        with open(metadata_path, "a") as f:
            json.dump(self.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")


class TrashItem(ABC):
    """Abstract base for items to be trashed."""

    def __init__(self, path: Path) -> None:
        self.path = path if path.is_absolute() else Path.cwd() / path

    @abstractmethod
    def trash(self, config: TrashConfig) -> Metadata:
        """Trash this item. Returns Metadata on success; raises RuntimeError on failure."""
        pass

    @classmethod
    def factory(cls, path: Path) -> "TrashItem":
        """Instantiate appropriate TrashItem subclass based on path type.

        Checks is_symlink() FIRST (before is_dir()) to avoid treating symlinks
        to directories as directories (D-06 pitfall: is_dir() follows symlinks).
        """
        if path.is_symlink():
            return Symlink(path)
        elif path.is_dir():
            return Directory(path)
        else:
            return RegularFile(path)


class Symlink(TrashItem):
    """Trash a symbolic link by moving it directly to trash."""

    def trash(self, config: TrashConfig) -> Metadata:
        """Move symlink directly to trash; preserve inode and target path.

        Raises:
            RuntimeError: If symlink cannot be trashed
        """
        try:
            # Hash based on symlink target string (readlink() returns Path)
            symlink_target = self.path.readlink()
            hash_value = hashlib.sha256(str(symlink_target).encode()).hexdigest()

            trash_path = config.trash_dir / hash_value
            config.trash_dir.mkdir(parents=True, exist_ok=True)

            # Note: shutil.move() requires trash_dir on same filesystem as self.path.
            # For cross-filesystem symlinks, this will raise OSError (acceptable per D-35).
            # Move symlink directly — shutil.move() preserves symlink, not target
            shutil.move(str(self.path), str(trash_path))

            # Record metadata with type="symlink"
            metadata = Metadata(self.path, hash=hash_value, item_type="symlink")
            metadata.write_to_jsonl(config.trash_dir / "metadata.jsonl")

            if config.verbose:
                print(
                    f"Trashed: {self.path} [hash: {hash_value}]",
                    file=sys.stderr,
                )
            return metadata
        except (OSError, RuntimeError) as e:
            raise RuntimeError(f"Failed to trash {self.path}: {e}") from e


class RegularFile(TrashItem):
    """Trash a regular file by hashing and moving to trash."""

    def trash(self, config: TrashConfig) -> Metadata:
        """Hash file and move to trash_dir/{hash}.

        Raises:
            RuntimeError: If file cannot be trashed
        """
        try:
            metadata = Metadata(self.path)
            assert metadata.hash is not None, "Regular file hash should never be None"
            trash_path = config.trash_dir / metadata.hash
            config.trash_dir.mkdir(parents=True, exist_ok=True)
            shutil.move(str(self.path), str(trash_path))
            metadata.write_to_jsonl(config.trash_dir / "metadata.jsonl")

            if config.verbose:
                print(
                    f"Trashed: {self.path} [hash: {metadata.hash}]",
                    file=sys.stderr,
                )
            return metadata
        except (OSError, RuntimeError, AssertionError) as e:
            raise RuntimeError(f"Failed to trash {self.path}: {e}") from e


class Directory(TrashItem):
    """Trash a directory by creating a tar archive and recording metadata."""

    def trash(self, config: TrashConfig) -> Metadata:
        """Tar directory contents, hash archive, move to trash, record metadata.

        Raises:
            RuntimeError: If directory cannot be trashed
        """
        try:
            hash_value, tar_path = self._tar_and_hash_dir(config)
            final_path = config.trash_dir / hash_value
            tar_path.rename(final_path)
            shutil.rmtree(self.path)
            metadata = Metadata(self.path, hash=hash_value, item_type="dir")
            metadata.write_to_jsonl(config.trash_dir / "metadata.jsonl")

            if config.verbose:
                print(
                    f"Trashed: {self.path} [hash: {hash_value}]",
                    file=sys.stderr,
                )
            return metadata
        except (OSError, subprocess.CalledProcessError, RuntimeError) as e:
            raise RuntimeError(f"Failed to trash {self.path}: {e}") from e

    def _tar_and_hash_dir(self, config: TrashConfig) -> tuple[str, Path]:
        """Create tar of directory contents in trash_dir, hash it, return (hash, temp_path).

        Uses trash_dir as temp location (D-08: same filesystem, atomic rename).
        Tar structure: -C dir_path . so tar contains ./file1, ./subdir/file2 etc.
        Original path is preserved in metadata — tar only needs contents (D-09).
        """
        temp_tar = config.trash_dir / f"tmp_{uuid.uuid4().hex[:8]}.tar"
        try:
            subprocess.run(
                ["tar", "-cf", str(temp_tar), "-C", str(self.path), "."],
                check=True,
                capture_output=True,
                text=False,
            )
            hash_value = Metadata._hash_file(temp_tar)  # type: ignore[reportPrivateUsage]
            return hash_value, temp_tar
        except subprocess.CalledProcessError as e:
            temp_tar.unlink(missing_ok=True)
            raise RuntimeError(f"Failed to tar directory: {e}") from e
        except RuntimeError:
            temp_tar.unlink(missing_ok=True)
            raise


def main() -> int:
    """Main entry point: orchestrate trash operations with configuration.

    Validates file arguments, builds TrashConfig, and delegates to TrashItem.factory()
    and trash() for each file. Exception handling is consolidated to three specific
    exception types: FileNotFoundError (missing file), ValueError (dangerous path),
    and RuntimeError (operation failure).
    """
    parser = argparse.ArgumentParser(
        prog="trash",
        description="Move files and directories to a backup location (~/.trash)",
        epilog=(
            "Examples:\n"
            "  trash file1.txt\n"
            "  trash file1 file2 directory/\n"
            "  trash -r important_dir/\n"
            "  trash -v -r backup.tar.gz\n"
            "  trash -f old_nonexistent_file\n"
            "\n"
            "Note: Files are moved to ~/.trash for recovery."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=True,
    )

    parser.add_argument(
        "-r",
        "--recursive",
        action="store_true",
        help="Required for directories (compress with tar)",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true", help="Show hashes for trashed items"
    )
    parser.add_argument(
        "-f", "--force", action="store_true", help="Ignore nonexistent files"
    )
    parser.add_argument("files", nargs="*", help="Files or directories to trash")

    args = parser.parse_args()

    # Check if files provided
    if not args.files:
        print("Error: Missing file arguments", file=sys.stderr)
        parser.print_help(sys.stderr)
        return EXIT_FAILURE

    # Build TrashConfig once after args parse
    trash_dir = Path(os.environ.get("TRASH_DIR", DEFAULT_TRASH_DIR))
    config = TrashConfig(
        trash_dir=trash_dir,
        verbose=args.verbose,
        force=args.force,
        recursive=args.recursive,
    )

    # Process each file
    had_error = False
    for file_arg in args.files:
        try:
            file_path = Path(file_arg)
            # Metadata.from_path() validates and normalizes; raises FileNotFoundError/ValueError
            Metadata.from_path(file_path)

            # Check directory requires -r (permission-aware guard, not validation)
            # Create TrashItem to determine type without full trash operation
            item = TrashItem.factory(file_path)
            if isinstance(item, Directory) and not config.recursive:
                print(
                    f"Error trashing {file_path}: Cannot trash directory without -r flag",
                    file=sys.stderr,
                )
                had_error = True
                continue

            # Trash the item with config
            item.trash(config)
        except FileNotFoundError:
            if not config.force:
                print(
                    f"Error trashing {file_arg}: No such file or directory",
                    file=sys.stderr,
                )
                had_error = True
        except ValueError as e:
            print(f"Error trashing {file_arg}: {e}", file=sys.stderr)
            had_error = True
        except RuntimeError as e:
            print(f"Error trashing {file_arg}: {e}", file=sys.stderr)
            had_error = True

    return EXIT_FAILURE if had_error else EXIT_SUCCESS


if __name__ == "__main__":
    sys.exit(main())

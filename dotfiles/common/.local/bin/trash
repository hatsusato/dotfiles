#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import sys
import argparse
import json
import os
import uuid
from abc import ABC, abstractmethod
from pathlib import Path
from datetime import datetime, timezone
import tempfile
import subprocess
import hashlib
import shutil

# Constants
DEFAULT_TRASH_DIR = Path.home() / ".trash"
EXIT_SUCCESS = 0
EXIT_FAILURE = 1


class Metadata:
    """Record of a trashed item: hash, original path, type, date."""

    def __init__(self, hash: str, path: Path, item_type: str, date: str) -> None:
        self.hash = hash
        self.path = path
        self.type = item_type
        self.date = date

    def to_dict(self) -> dict[str, str]:
        """Convert to JSON-serializable dict."""
        return {
            "hash": self.hash,
            "path": str(self.path),
            "type": self.type,
            "date": self.date,
        }

    @classmethod
    def from_dict(cls, d: dict[str, str]) -> "Metadata":
        """Deserialize from JSON dict."""
        return cls(
            hash=d["hash"],
            path=Path(d["path"]),
            item_type=d["type"],
            date=d["date"],
        )

    def write_to_jsonl(self, metadata_path: Path) -> None:
        """Append this metadata entry to metadata.jsonl in JSON Lines format."""
        metadata_path.parent.mkdir(parents=True, exist_ok=True)
        with open(metadata_path, "a") as f:
            json.dump(self.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")


class TrashItem(ABC):
    """Abstract base for items to be trashed."""

    def __init__(self, path: Path) -> None:
        self.path = path if path.is_absolute() else Path.cwd() / path

    @abstractmethod
    def trash(self, trash_dir: Path, verbose: bool, force: bool) -> Metadata:
        """Trash this item. Returns Metadata on success; raises RuntimeError on failure."""
        pass

    @classmethod
    def factory(cls, path: Path) -> "TrashItem":
        """Instantiate appropriate TrashItem subclass based on path type.

        Checks is_symlink() FIRST (before is_dir()) to avoid treating symlinks
        to directories as directories (D-06 pitfall: is_dir() follows symlinks).
        """
        if path.is_symlink():
            return Symlink(path)
        elif path.is_dir():
            return Directory(path)
        else:
            return RegularFile(path)

    def _hash_file(self, file_path: Path) -> str:
        """Compute SHA256 hash of file in 8KB chunks.

        Raises:
            RuntimeError: If file cannot be read
        """
        sha256 = hashlib.sha256()
        try:
            with open(file_path, "rb") as f:
                for chunk in iter(lambda: f.read(8192), b""):
                    sha256.update(chunk)
            return sha256.hexdigest()
        except (FileNotFoundError, PermissionError, IOError) as e:
            raise RuntimeError(f"Failed to hash file: {e}") from e

    def _record_metadata(
        self,
        trash_dir: Path,
        hash_value: str,
        original_path: Path,
        is_directory: bool,
    ) -> Metadata:
        """Create and persist Metadata record. Returns the Metadata object."""
        abs_path = (
            original_path if original_path.is_absolute() else Path.cwd() / original_path
        )
        metadata = Metadata(
            hash=hash_value,
            path=abs_path,
            item_type="dir" if is_directory else "file",
            date=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S"),
        )
        try:
            metadata.write_to_jsonl(trash_dir / "metadata.jsonl")
        except (IOError, PermissionError) as e:
            raise RuntimeError(f"Failed to record metadata: {e}") from e
        return metadata


class Symlink(TrashItem):
    """Trash a symbolic link by recording its target as a file."""

    def trash(self, trash_dir: Path, verbose: bool, force: bool) -> Metadata:
        """Move symlink target record to trash; delete the symlink itself.

        Raises:
            RuntimeError: If symlink cannot be trashed
        """
        tmp_path: Path | None = None
        try:
            symlink_target = self.path.readlink()
            tmp_file = tempfile.NamedTemporaryFile(delete=False)
            tmp_path = Path(tmp_file.name)
            tmp_file.write(str(symlink_target).encode("utf-8"))
            tmp_file.close()

            hash_value = self._hash_file(tmp_path)
            trash_path = trash_dir / hash_value
            trash_dir.mkdir(parents=True, exist_ok=True)
            shutil.move(str(tmp_path), str(trash_path))
            self.path.unlink()
            metadata = self._record_metadata(trash_dir, hash_value, self.path, False)

            if verbose:
                print(
                    f"Trashed: {self.path} [hash: {hash_value}]",
                    file=sys.stderr,
                )
            return metadata
        except (OSError, RuntimeError) as e:
            try:
                if tmp_path is not None:
                    tmp_path.unlink(missing_ok=True)
            except OSError:
                pass
            raise RuntimeError(f"Failed to trash {self.path}: {e}") from e


class RegularFile(TrashItem):
    """Trash a regular file by hashing and moving to trash."""

    def trash(self, trash_dir: Path, verbose: bool, force: bool) -> Metadata:
        """Hash file and move to trash_dir/{hash}.

        Raises:
            RuntimeError: If file cannot be trashed
        """
        try:
            hash_value = self._hash_file(self.path)
            trash_path = trash_dir / hash_value
            trash_dir.mkdir(parents=True, exist_ok=True)
            shutil.move(str(self.path), str(trash_path))
            metadata = self._record_metadata(trash_dir, hash_value, self.path, False)

            if verbose:
                print(
                    f"Trashed: {self.path} [hash: {hash_value}]",
                    file=sys.stderr,
                )
            return metadata
        except (OSError, RuntimeError) as e:
            raise RuntimeError(f"Failed to trash {self.path}: {e}") from e


class Directory(TrashItem):
    """Trash a directory by creating a tar archive and recording metadata."""

    def trash(self, trash_dir: Path, verbose: bool, force: bool) -> Metadata:
        """Tar directory contents, hash archive, move to trash, record metadata.

        Raises:
            RuntimeError: If directory cannot be trashed
        """
        try:
            hash_value, tar_path = self._tar_and_hash_dir(trash_dir)
            final_path = trash_dir / hash_value
            tar_path.rename(final_path)
            shutil.rmtree(self.path)
            metadata = self._record_metadata(trash_dir, hash_value, self.path, True)

            if verbose:
                print(
                    f"Trashed: {self.path} [hash: {hash_value}]",
                    file=sys.stderr,
                )
            return metadata
        except (OSError, subprocess.CalledProcessError, RuntimeError) as e:
            raise RuntimeError(f"Failed to trash {self.path}: {e}") from e

    def _tar_and_hash_dir(self, trash_dir: Path) -> tuple[str, Path]:
        """Create tar of directory contents in trash_dir, hash it, return (hash, temp_path).

        Uses trash_dir as temp location (D-08: same filesystem, atomic rename).
        Tar structure: -C dir_path . so tar contains ./file1, ./subdir/file2 etc.
        Original path is preserved in metadata — tar only needs contents (D-09).
        """
        temp_tar = trash_dir / f"tmp_{uuid.uuid4().hex[:8]}.tar"
        try:
            subprocess.run(
                ["tar", "-cf", str(temp_tar), "-C", str(self.path), "."],
                check=True,
                capture_output=True,
                text=False,
            )
            hash_value = self._hash_file(temp_tar)
            return hash_value, temp_tar
        except subprocess.CalledProcessError as e:
            temp_tar.unlink(missing_ok=True)
            raise RuntimeError(f"Failed to tar directory: {e}") from e
        except RuntimeError:
            temp_tar.unlink(missing_ok=True)
            raise


def _hash_file(path: Path) -> str:
    """Compute SHA256 hash of file in 8KB chunks.

    Args:
        path: Path to file to hash

    Returns:
        Hexadecimal hash string (no filename)

    Raises:
        RuntimeError: If file cannot be read
    """
    sha256 = hashlib.sha256()
    try:
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                sha256.update(chunk)
        return sha256.hexdigest()
    except (FileNotFoundError, PermissionError, IOError) as e:
        raise RuntimeError(f"Failed to hash file: {e}")


def _tar_and_hash_dir(dir_path: Path, temp_dir: Path) -> tuple[str, Path]:
    """Create uncompressed tar archive of directory, then hash it.

    Args:
        dir_path: Path to directory to tar
        temp_dir: Temporary directory for tar file

    Returns:
        Tuple of (hash_value, tar_path)

    Raises:
        RuntimeError: If tar creation or hashing fails
    """
    # Create temporary tar file
    tar_file = tempfile.NamedTemporaryFile(suffix=".tar", dir=temp_dir, delete=False)
    tar_path = Path(tar_file.name)
    tar_file.close()

    try:
        # Create uncompressed tar (D-09: contents only, no dir name prefix)
        subprocess.run(
            ["tar", "-cf", str(tar_path), "-C", str(dir_path), "."],
            check=True,
            capture_output=True,
            text=False,
        )

        # Hash the tar archive
        hash_value = _hash_file(tar_path)
        return hash_value, tar_path
    except subprocess.CalledProcessError as e:
        tar_path.unlink(missing_ok=True)
        raise RuntimeError(f"Failed to compress directory: {e}")
    except RuntimeError:
        tar_path.unlink(missing_ok=True)
        raise


def _record_metadata(
    trash_dir: Path, hash_value: str, original_path: Path, is_directory: bool
) -> None:
    """Append metadata entry to metadata.jsonl using Metadata class."""
    abs_path = (
        original_path if original_path.is_absolute() else Path.cwd() / original_path
    )
    metadata = Metadata(
        hash=hash_value,
        path=abs_path,
        item_type="dir" if is_directory else "file",
        date=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S"),
    )
    try:
        metadata.write_to_jsonl(trash_dir / "metadata.jsonl")
    except (IOError, PermissionError) as e:
        raise RuntimeError(f"Failed to record metadata: {e}") from e


def _trash_symlink(symlink_path: Path, trash_dir: Path, verbose: bool) -> bool:
    """Trash a symlink by recording its target path as content."""
    tmp_path: Path | None = None
    try:
        symlink_target = symlink_path.readlink()
        tmp_file = tempfile.NamedTemporaryFile(delete=False)
        tmp_path = Path(tmp_file.name)
        tmp_file.write(str(symlink_target).encode("utf-8"))
        tmp_file.close()

        hash_value = _hash_file(tmp_path)
        trash_path = trash_dir / hash_value

        trash_dir.mkdir(parents=True, exist_ok=True)
        shutil.move(str(tmp_path), str(trash_path))
        symlink_path.unlink()
        _record_metadata(trash_dir, hash_value, symlink_path, False)

        if verbose:
            print(f"Trashed: {symlink_path} [hash: {hash_value}]", file=sys.stderr)
        return True
    except (OSError, RuntimeError) as e:
        print(f"Error trashing {symlink_path}: {e}", file=sys.stderr)
        try:
            if tmp_path is not None:
                tmp_path.unlink(missing_ok=True)
        except OSError:
            pass  # Cleanup best-effort
        return False


def _trash_directory(dir_path: Path, trash_dir: Path, verbose: bool) -> bool:
    """Trash a directory by creating a tar archive and recording metadata."""
    try:
        hash_value, tar_path = _tar_and_hash_dir(dir_path, Path(tempfile.gettempdir()))
        trash_path = trash_dir / hash_value

        trash_dir.mkdir(parents=True, exist_ok=True)
        shutil.move(str(tar_path), str(trash_path))
        shutil.rmtree(dir_path)
        _record_metadata(trash_dir, hash_value, dir_path, True)

        if verbose:
            print(f"Trashed: {dir_path} [hash: {hash_value}]", file=sys.stderr)
        return True
    except (OSError, RuntimeError) as e:
        print(f"Error trashing {dir_path}: {e}", file=sys.stderr)
        return False


def _trash_regular_file(file_path: Path, trash_dir: Path, verbose: bool) -> bool:
    """Trash a regular file by hashing and moving to trash."""
    try:
        hash_value = _hash_file(file_path)
        trash_path = trash_dir / hash_value

        trash_dir.mkdir(parents=True, exist_ok=True)
        shutil.move(str(file_path), str(trash_path))
        _record_metadata(trash_dir, hash_value, file_path, False)

        if verbose:
            print(f"Trashed: {file_path} [hash: {hash_value}]", file=sys.stderr)
        return True
    except (OSError, RuntimeError) as e:
        print(f"Error trashing {file_path}: {e}", file=sys.stderr)
        return False


def _trash_file(
    file_path: Path, trash_dir: Path, is_directory: bool, force: bool, verbose: bool
) -> bool:
    """Dispatch file, symlink, or directory to the appropriate trash handler."""
    try:
        # Make path absolute without following symlinks
        if not file_path.is_absolute():
            file_path = Path.cwd() / file_path

        # Check existence before symlink check (symlink may point to nonexistent)
        if not file_path.exists() and not file_path.is_symlink():
            if not force:
                print(
                    f"Error trashing {file_path}: No such file or directory",
                    file=sys.stderr,
                )
                return False
            return True  # Force: silently ignore

        # Refuse dangerous paths (resolved for real paths, raw for broken symlinks)
        abs_path = (
            file_path.resolve()
            if file_path.exists() or not file_path.is_symlink()
            else file_path
        )
        if abs_path == Path("/") or abs_path == Path.home() or abs_path == Path("."):
            print(
                f"Error trashing {file_path}: Cannot trash system directory",
                file=sys.stderr,
            )
            return False

        # Create trash directory
        try:
            trash_dir.mkdir(parents=True, exist_ok=True)
        except (OSError, PermissionError) as e:
            print(
                f"Error trashing {file_path}: Failed to create trash directory: {e}",
                file=sys.stderr,
            )
            return False

        # Dispatch to type-specific handler
        if file_path.is_symlink():
            return _trash_symlink(file_path, trash_dir, verbose)
        elif is_directory:
            return _trash_directory(file_path, trash_dir, verbose)
        else:
            return _trash_regular_file(file_path, trash_dir, verbose)

    except Exception as e:
        print(f"Error trashing {file_path}: {e}", file=sys.stderr)
        return False


def main() -> int:
    """Main entry point."""
    parser = argparse.ArgumentParser(
        prog="trash",
        description="Move files and directories to a backup location (~/.trash)",
        epilog=(
            "Examples:\n"
            "  trash file1.txt\n"
            "  trash file1 file2 directory/\n"
            "  trash -r important_dir/\n"
            "  trash -v -r backup.tar.gz\n"
            "  trash -f old_nonexistent_file\n"
            "\n"
            "Note: Files are moved to ~/.trash for recovery."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=True,
    )

    parser.add_argument(
        "-r",
        "--recursive",
        action="store_true",
        help="Required for directories (compress with tar)",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true", help="Show hashes for trashed items"
    )
    parser.add_argument(
        "-f", "--force", action="store_true", help="Ignore nonexistent files"
    )
    parser.add_argument("files", nargs="*", help="Files or directories to trash")

    args = parser.parse_args()

    # Check if files provided
    if not args.files:
        print("Error: Missing file arguments", file=sys.stderr)
        parser.print_help(sys.stderr)
        return EXIT_FAILURE

    # Get trash directory from environment or use default
    trash_dir = Path(os.environ.get("TRASH_DIR", DEFAULT_TRASH_DIR))

    # Process each file
    had_error = False
    for file_arg in args.files:
        file_path = Path(file_arg)

        # Determine if this is a directory (check symlink first!)
        is_directory = False
        if file_path.is_symlink():
            # Symlinks are never treated as directories, even if they point to one
            is_directory = False
        elif file_path.is_dir():
            is_directory = True

        # Check directory without -r flag
        if is_directory and not args.recursive:
            print(
                f"Error trashing {file_path}: Cannot trash directory without -r flag",
                file=sys.stderr,
            )
            had_error = True
            continue

        # Trash the file
        if not _trash_file(
            file_path, trash_dir, is_directory, args.force, args.verbose
        ):
            had_error = True
        # Continue to next file regardless of error

    return EXIT_FAILURE if had_error else EXIT_SUCCESS


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import json
import os
import shutil
import sys
import time
from argparse import ArgumentParser, Namespace, RawDescriptionHelpFormatter
from dataclasses import dataclass
from dataclasses import replace as dataclass_replace
from datetime import datetime
from pathlib import Path


@dataclass
class TrashEvent:
    """Single event in trash-log.jsonl — immutable data container."""

    path: str
    timestamp: int  # Epoch when trashed (= filename in .trash/)
    restore: bool = False

    def to_dict(self) -> dict[str, str | int | bool]:
        """Convert to JSON-serializable dict for trash-log.jsonl."""
        return {
            "path": self.path,
            "timestamp": self.timestamp,
            "restore": self.restore,
        }

    @classmethod
    def from_dict(cls, d: dict[str, str | int | bool]) -> "TrashEvent":
        """Deserialize from JSON dict."""
        return cls(
            path=str(d["path"]),
            timestamp=int(d["timestamp"]),
            restore=bool(d.get("restore", False)),
        )


class TrashLog:
    """Manages trash-log.jsonl as append-only event log.

    Loads entire event history into memory at init for fast queries.
    Stores events as dict[str, list[TrashEvent]] keyed by path for O(1) lookup.
    Provides active_events(), make_trash_event(), execute_trash(), trash_item(),
    and restore_item().
    """

    def __init__(self, trash_dir: Path | None = None) -> None:
        """Initialize TrashLog; defaults to TRASH_DIR env or ~/.trash."""
        if trash_dir is None:
            trash_dir = Path(os.getenv("TRASH_DIR", str(Path.home() / ".trash")))
        self._trash_dir = trash_dir
        self._metadata_path = trash_dir / "trash-log.jsonl"
        self._events: dict[str, list[TrashEvent]] = {}
        self._reserved_timestamps: set[int] = set()
        self._trash_dir.mkdir(parents=True, exist_ok=True)  # D-07: create once
        self.load()

    def _get_unique_timestamp(self) -> int:
        """Return first available epoch timestamp in self._trash_dir.

        Starts at current epoch, increments by 1 until a non-existing
        name is found in self._trash_dir and the timestamp is not already
        reserved by a pending make_trash_event() call. This ensures that
        batch make_trash_event() calls in Phase 1 of the two-phase pattern
        each receive a distinct timestamp before any execute_trash() runs.
        """
        timestamp = int(time.time())
        while (
            self._trash_dir / str(timestamp)
        ).exists() or timestamp in self._reserved_timestamps:
            timestamp += 1
        self._reserved_timestamps.add(timestamp)
        return timestamp

    def _get_trash_path(self, timestamp: int) -> Path:
        """Returns the path to the trashed item (trash_dir/{timestamp})."""
        return self._trash_dir / str(timestamp)

    def make_trash_event(self, path: Path, restore: bool = False) -> TrashEvent:
        """Generate or find TrashEvent. No file I/O.

        For trash (restore=False): creates new event with unique timestamp.
        For restore (restore=True): finds latest restorable event in log.

        Used in two-stage pattern: generate event, inspect, then execute.
        Timestamp generation uses _get_unique_timestamp() for collision avoidance.

        Note: The timestamp is not reserved between make_trash_event() and
        execute_trash(). A concurrent trash invocation could claim the same
        timestamp in that window. This design assumes single-user (non-concurrent)
        usage, which is the typical interactive shell scenario.

        Args:
            path: Path to file/directory to trash or restore
            restore: If True, find existing restorable event; if False, create new

        Returns:
            TrashEvent: Generated or found event (not yet executed)

        Raises:
            ValueError: If restore=True and no restorable entry exists for path
        """
        if restore:
            events_for_path = self._events.get(str(path), [])
            if not events_for_path:
                raise ValueError(f"No trash entry found for {path}")
            latest = max(events_for_path, key=lambda e: e.timestamp)
            if latest.restore:
                raise ValueError(
                    f"No restorable entry found for {path}:"
                    " most recent entry is already restored"
                )
            # Return a restore-flagged copy of the trash event so that
            # execute_trash() can dispatch correctly on event.restore.
            return dataclass_replace(latest, restore=True)
        timestamp = self._get_unique_timestamp()
        return TrashEvent(path=str(path), timestamp=timestamp)

    def execute_trash(self, event: TrashEvent) -> None:
        """Execute trash or restore operation based on event.restore flag.

        Counterpart to make_trash_event(): performs the actual file I/O.
        Used in two-stage pattern after event inspection/transformation.

        Args:
            event: TrashEvent controlling operation type via event.restore flag

        Raises:
            FileNotFoundError: Source path doesn't exist (trash) or trash item
                missing (restore)
            shutil.Error: File operation fails
        """
        if event.restore:
            target_path = Path(event.path)
            trash_path = self._get_trash_path(event.timestamp)
            if not os.path.lexists(trash_path):
                raise FileNotFoundError(
                    f"Trash item missing: {trash_path} (timestamp: {event.timestamp})"
                )
            target_path.parent.mkdir(parents=True, exist_ok=True)
            if os.path.lexists(target_path):
                print(
                    f"trash: {target_path} exists; backing up to trash...",
                    file=sys.stderr,
                )
                self.trash_item(target_path)
            shutil.move(str(trash_path), str(target_path))
            self.mark_restored(event.path)
        else:
            dest = self._get_trash_path(event.timestamp)
            shutil.move(str(event.path), str(dest))
            self._reserved_timestamps.discard(event.timestamp)
            self.append(event)

    def trash_item(self, path: Path) -> TrashEvent:
        """Move path to trash and record event in log (atomic operation).

        Delegates to make_trash_event() + execute_trash() two-stage pattern.

        Args:
            path: Path to file/directory to trash

        Returns:
            TrashEvent: The event recorded (includes path, timestamp, restore flag)
        """
        event = self.make_trash_event(path)
        self.execute_trash(event)
        return event

    def load(self) -> None:
        """Read and parse trash-log.jsonl, rebuild in-memory event dict.

        Handles missing file, empty file gracefully.
        Tolerates a single truncated final line (crash-during-write pattern).
        Raises ValueError on malformed lines that are not at end-of-file.

        Note: Changes to _events must be persisted via append().
        """
        self._events = {}
        if not self._metadata_path.exists():
            return

        with open(self._metadata_path) as f:
            raw_lines = f.readlines()

        total_lines = len(raw_lines)
        for lineno, line in enumerate(raw_lines, 1):
            line = line.strip()
            if not line:
                continue
            try:
                entry_dict = json.loads(line)
                event = TrashEvent.from_dict(entry_dict)
                self._events.setdefault(event.path, []).append(event)
            except (json.JSONDecodeError, KeyError, ValueError) as e:
                # Tolerate truncated final line only (crash leaves no trailing newline).
                # A complete line ending with "\n" is not crash residue — always raise.
                if lineno == total_lines and not raw_lines[-1].endswith("\n"):
                    break
                raise ValueError(
                    f"Malformed metadata entry at line {lineno}: {e}"
                ) from e

    def active_events(self) -> list[TrashEvent]:
        """Return currently-trashed events (latest per path is not a restore event).

        Uses timestamp-based filtering (max timestamp per path), independent of
        append order. Each path's latest event is checked for restore=False.
        """
        result: list[TrashEvent] = []
        for _path, events_for_path in self._events.items():
            latest = max(events_for_path, key=lambda e: e.timestamp)
            if not latest.restore:
                result.append(latest)
        return result

    def append(self, event: TrashEvent) -> None:
        """Add event to memory and sync to disk immediately."""
        self._events.setdefault(event.path, []).append(event)
        self._append_jsonl(event)

    def mark_restored(self, path: str) -> None:
        """Append new event with restore=True to create audit trail.

        Uses _get_unique_timestamp() to ensure timestamp is strictly greater
        than the trash event timestamp, so max() lookups work correctly.
        """
        restore_event = TrashEvent(
            path=path,
            timestamp=self._get_unique_timestamp(),
            restore=True,
        )
        self.append(restore_event)

    def _append_jsonl(self, event: TrashEvent) -> None:
        """Append single line to trash-log.jsonl with fsync.

        Not atomic: a crash during write may leave a partial final line.
        load() tolerates such truncation via partial-last-line detection.
        """
        with open(self._metadata_path, "a") as f:
            json.dump(
                event.to_dict(),
                f,
                ensure_ascii=False,
                separators=(",", ":"),
            )
            f.write("\n")
            os.fsync(f.fileno())


def normalize_path(path: Path | str) -> Path:
    """Validate and normalize path to absolute resolved form.

    Encapsulates path normalization, existence checking, and dangerous path
    detection. Returns a plain Path (not a subclass).

    Args:
        path: Relative or absolute file path

    Returns:
        Path: Absolute, resolved path

    Raises:
        FileNotFoundError: Path does not exist and is not a symlink
        ValueError: Path is a dangerous system directory under cwd
    """
    absolute_path = Path(path).absolute()
    resolved = absolute_path.parent.resolve() / absolute_path.name
    if not os.path.lexists(resolved):  # D-08: lexists() applied (location 1)
        raise FileNotFoundError(f"{path}: No such file or directory")
    if Path.cwd().is_relative_to(resolved):
        raise ValueError(f"Cannot trash system directory: {path}")
    return resolved


class TrashConfig(Namespace):
    """Configuration for trash operations — argparse Namespace subclass.

    Hides ArgumentParser as internal state. External callers use only:
    - TrashConfig.parse_args(args=None) -> TrashConfig
    - config.print_help()
    """

    verbose: bool = False
    force: bool = False
    recursive: bool = False
    files: list[Path] = None  # type: ignore[assignment]  # argparse always sets this
    restore: bool = False
    show_list: bool = False

    @classmethod
    def _build_parser(cls) -> ArgumentParser:
        """Internal: construct and return ArgumentParser.

        Contains all parser configuration for the trash command.
        Must not be called directly from outside TrashConfig.
        """
        epilog = [
            "Examples:",
            "  trash file1.txt",
            "  trash file1 file2 directory/",
            "  trash -r important_dir/",
            "  trash -v -r backup.tar.gz",
            "  trash -f old_nonexistent_file",
            "  trash --restore /path/to/file",
            "  trash --list",
            "",
            "Note: Files are moved to ~/.trash for recovery.",
        ]
        parser = ArgumentParser(
            prog="trash",
            description="Safe deletion and recovery via backup location (~/.trash)",
            epilog=("\n".join(epilog)),
            formatter_class=RawDescriptionHelpFormatter,
            add_help=True,
        )
        parser.add_argument(
            "--restore",
            action="store_true",
            help="Restore file(s) from trash by their original path",
        )
        parser.add_argument(
            "--list",
            "-l",
            action="store_true",
            dest="show_list",
            help="List all items in trash",
        )
        parser.add_argument(
            "-r",
            "--recursive",
            action="store_true",
            help="Required for directories",
        )
        parser.add_argument(
            "-v",
            "--verbose",
            action="store_true",
            help="Show timestamps for trashed items",
        )
        parser.add_argument(
            "-f", "--force", action="store_true", help="Ignore nonexistent files"
        )
        parser.add_argument(
            "files",
            nargs="*",
            type=Path,
            help="Files or directories to trash (or paths to restore with --restore)",
        )
        return parser

    @classmethod
    def parse_args(cls, args: list[str] | None = None) -> "TrashConfig":
        """Parse CLI arguments into TrashConfig instance.

        Hides ArgumentParser internals. Returns populated TrashConfig.
        """
        parser = cls._build_parser()
        return parser.parse_args(args, namespace=cls())

    def print_help(self) -> None:
        """Print help text to stdout."""
        self._build_parser().print_help()


EXIT_SUCCESS = 0
EXIT_FAILURE = 1
_LIST_START_INDEX = 1  # 1-based display numbering for --list output


def list_items(_config: "TrashConfig", trash_log: TrashLog) -> None:
    """Print trash-log.jsonl contents in human-readable format to stdout."""
    entries = trash_log.active_events()
    if not entries:
        return
    print(f"Files in trash ({len(entries)}):")
    for i, entry in enumerate(entries, _LIST_START_INDEX):
        print(f"  {i}. {entry.path}")
        dt_local = datetime.fromtimestamp(entry.timestamp).astimezone()
        ts_iso = dt_local.isoformat(timespec="seconds")
        print(f"     timestamp: {ts_iso}")


def main() -> int:
    """Main entry point: orchestrate trash, restore, or list operations."""
    config = TrashConfig.parse_args()
    trash_log = TrashLog()

    if config.show_list:
        list_items(config, trash_log)
        return EXIT_SUCCESS

    if config.restore:
        if not config.files:
            print("Error: provide a path to restore or use --list", file=sys.stderr)
            config.print_help()
            return EXIT_FAILURE
        # Phase 1: generate all restore events
        events: list[TrashEvent] = []
        success = True
        for path in config.files:
            abs_path = Path(str(path)).absolute()
            target_path = abs_path.parent.resolve() / abs_path.name
            try:
                event = trash_log.make_trash_event(target_path, restore=True)
                events.append(event)
            except ValueError as e:
                print(f"trash: error: {e}", file=sys.stderr)
                success = False
        # Phase 2: execute all restore events
        for event in events:
            try:
                trash_log.execute_trash(event)
            except (FileNotFoundError, shutil.Error, OSError) as e:
                print(f"trash: error restoring {event.path}: {e}", file=sys.stderr)
                success = False
                continue
            if config.verbose:
                print(
                    f"trash: restored {event.path} [timestamp: {event.timestamp}]",
                    file=sys.stderr,
                )
        return EXIT_SUCCESS if success else EXIT_FAILURE

    if not config.files:
        print("Error: Missing file arguments", file=sys.stderr)
        config.print_help()
        return EXIT_FAILURE

    # Phase 1: generate all trash events
    events = []
    success = True
    for path in config.files:
        try:
            trash_path = normalize_path(path)
            if trash_path.is_dir() and not config.recursive:
                raise ValueError("Cannot trash directory without -r flag")
            event = trash_log.make_trash_event(trash_path)
            events.append(event)
        except FileNotFoundError:
            if config.force:
                pass
            else:
                print(
                    f"Error trashing {path}: No such file or directory",
                    file=sys.stderr,
                )
                success = False
        except (ValueError, RuntimeError) as e:
            print(f"Error trashing {path}: {e}", file=sys.stderr)
            success = False
    # Phase 2: execute all trash events
    for event in events:
        try:
            trash_log.execute_trash(event)
        except (FileNotFoundError, shutil.Error, OSError) as e:
            print(f"Error trashing {event.path}: {e}", file=sys.stderr)
            success = False
            continue
        if config.verbose:
            print(
                f"Trashed: {event.path} [timestamp: {event.timestamp}]",
                file=sys.stderr,
            )
    return EXIT_SUCCESS if success else EXIT_FAILURE


if __name__ == "__main__":
    sys.exit(main())

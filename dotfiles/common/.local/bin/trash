#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import hashlib
import json
import os
import shutil
import subprocess
import sys
from argparse import ArgumentParser, RawDescriptionHelpFormatter
from contextlib import contextmanager
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from tempfile import NamedTemporaryFile
from typing import Literal, Self


class TrashPath(Path):
    """Path subclass with type detection and validation.

    Validates path at creation time: checks existence, detects type,
    prevents dangerous paths. Inherits from Path for transparent API access.
    """

    @classmethod
    def create(cls, path: Path | str) -> Self:
        """Validate and create TrashPath.

        Encapsulates path normalization, existence checking, and dangerous path
        detection. All validation logic is centralized here.

        Args:
            path: Relative or absolute file path

        Returns:
            TrashPath instance (a Path subclass)

        Raises:
            FileNotFoundError: Path does not exist and is not a symlink
            ValueError: Path is a dangerous system directory under cwd
        """
        # Normalize path to absolute
        absolute_path = Path(path).absolute()
        resolved = absolute_path.parent.resolve() / absolute_path.name
        # Check existence (symlinks may point to nonexistent targets — check both)
        if not resolved.exists() and not resolved.is_symlink():
            raise FileNotFoundError(f"{path}: No such file or directory")
        # Reject if resolved is ancestor of cwd (system directory)
        if Path.cwd().is_relative_to(resolved):
            raise ValueError(f"Cannot trash system directory: {path}")
        # Create Path instance
        return cls(resolved)


class Metadata:
    """Record of a trashed item: hash, original path, type, date.

    Pure data container — stores validated path, hash, type, and date.
    """

    def __init__(
        self,
        hash: str,
        path: str,
        type: Literal["file", "dir", "symlink"],
        date: str = "",
    ) -> None:
        """Initialize Metadata with hash, path, type, and optional date.

        Args:
            hash: SHA256 hash hexdigest of item content or symlink target
            path: Original path of the trashed item (as string)
            type: Type of item ("file", "dir", or "symlink")
            date: Optional ISO8601 timestamp; defaults to current time if omitted
        """
        self.hash = hash
        self.path = path
        self.type = type
        self.date = date if date else self.now()

    def to_dict(self) -> dict[str, str]:
        """Convert to JSON-serializable dict."""
        return dict(hash=self.hash, path=self.path, type=self.type, date=self.date)

    @classmethod
    def from_dict(cls, d: dict[str, str]) -> Self:
        """Deserialize from JSON dict."""
        if d["type"] not in ("file", "dir", "symlink"):
            raise ValueError(f"Invalid type in metadata: {d['type']}")
        return cls(hash=d["hash"], path=d["path"], type=d["type"], date=d["date"])

    @staticmethod
    def now() -> str:
        """Return current timestamp in ISO8601 UTC format.

        Returns:
            ISO8601 formatted timestamp string (YYYY-MM-DDTHH:MM:SS)
        """
        return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S")


@dataclass
class TrashConfig:
    """Immutable configuration for trash operations.

    Dataclass enforces field ordering: verbose, force, recursive must be
    provided by caller; trash_dir defaults to TrashDir() which reads TRASH_DIR
    environment variable at instantiation time.
    """

    verbose: bool
    force: bool
    recursive: bool
    # Default: read TRASH_DIR env var or ~/.trash
    trash_dir_path = Path(os.getenv("TRASH_DIR", Path.home() / ".trash"))

    def get_trash_path(self, hash_value: str) -> Path:
        """Get final trash path for given hash.

        Ensures trash directory and its parents exist, then returns the
        path to the trashed item (trash_dir/{hash_value}).

        Args:
            hash_value: SHA256 hash hexdigest of item content or symlink target

        Returns:
            Path to the trashed item in trash_dir
        """
        trash_path = self.trash_dir_path / hash_value
        trash_path.parent.mkdir(parents=True, exist_ok=True)
        return trash_path

    @contextmanager
    def get_temp_file(self, prefix: str | None = None, suffix: str | None = None):
        """Context manager for creating a temporary file in trash_dir.

        Creates NamedTemporaryFile with delete=False, so caller must delete it
        explicitly. If an exception occurs, file is deleted automatically.

        Args:
            prefix: Optional prefix for temp file name
            suffix: Optional suffix for temp file name (e.g., ".tar")

        Yields:
            NamedTemporaryFile instance (already created and open)
        """
        tmp = NamedTemporaryFile(
            delete=False, dir=self.trash_dir_path, prefix=prefix, suffix=suffix
        )
        success = False
        try:
            yield tmp
            success = True
        finally:
            tmp.close()
            if not success:
                os.unlink(tmp.name)

    def write_metadata(self, metadata: Metadata) -> None:
        """Append this metadata entry to metadata.jsonl in JSON Lines format.

        Each line is a complete JSON object representing one trashed item.
        Uses ensure_ascii=False to preserve original characters; separators
        to minimize output size.

        Args:
            metadata: Metadata entry to write
        """
        metadata_path = self.trash_dir_path / "metadata.jsonl"
        metadata_path.parent.mkdir(parents=True, exist_ok=True)
        with open(metadata_path, "a") as f:
            json.dump(metadata.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")

    def trash_symlink(self, path: TrashPath) -> Metadata:
        """Trash a symlink by hashing its target and moving it to trash.

        Hash is computed from symlink target string. Returns Metadata with hash set.

        Args:
            path: Path to symlink

        Returns:
            Metadata with hash and type set

        Raises:
            RuntimeError: If symlink cannot be trashed
        """
        hash_value = _hash_str(str(path.readlink()))
        trash_path = self.get_trash_path(hash_value)
        shutil.move(path, trash_path)
        return Metadata(hash=hash_value, path=str(path), type="symlink")

    def trash_dir(self, path: TrashPath) -> Metadata:
        """Trash a directory by creating a tar of its contents and moving it to trash.

        Returns Metadata with hash set.

        Args:
            path: Path to directory

        Returns:
            Metadata with hash and type set

        Raises:
            RuntimeError: If directory cannot be trashed
        """
        # Check -r guard (permission-aware guard, not validation)
        if not self.recursive:
            raise ValueError("Cannot trash directory without -r flag")
        with self.get_temp_file(suffix=".tar") as tmp:
            cmd = ["tar", "-cf", tmp.name, "-C", str(path), "."]
            subprocess.run(cmd, check=True)
            tar_path = Path(tmp.name)
        hash_value = _hash_file(tar_path)
        trash_path = self.get_trash_path(hash_value)
        tar_path.rename(trash_path)
        shutil.rmtree(path)
        return Metadata(hash=hash_value, path=str(path), type="dir")

    def trash_file(self, path: TrashPath) -> Metadata:
        """Trash a regular file by hashing it and moving it to trash.

        Returns Metadata with hash set.

        Args:
            path: Path to file

        Returns:
            Metadata with hash and type set

        Raises:
            RuntimeError: If file cannot be trashed
        """
        hash_value = _hash_file(path)
        trash_path = self.get_trash_path(hash_value)
        shutil.move(path, trash_path)
        return Metadata(hash=hash_value, path=str(path), type="file")


def _hash_str(s: str) -> str:
    """Compute SHA256 hash of a string.

    Pure function for hashing strings. Takes explicit string parameter,
    returns computed hash string. No state mutation.

    Args:
        s: Input string to hash

    Returns:
        SHA256 hexdigest as string
    """
    return hashlib.sha256(s.encode()).hexdigest()


def _hash_file(file_path: Path) -> str:
    """Compute SHA256 hash of file in 8KB chunks.

    Pure function for hashing files. Takes explicit path parameter,
    returns computed hash string. No state mutation.

    Args:
        file_path: Path to file to hash

    Returns:
        SHA256 hexdigest as string

    Raises:
        RuntimeError: If file cannot be read
    """
    sha256 = hashlib.sha256()
    try:
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                sha256.update(chunk)
        return sha256.hexdigest()
    except (FileNotFoundError, PermissionError, IOError) as e:
        raise RuntimeError(f"Failed to hash file: {e}") from e


def _setup_parser() -> ArgumentParser:
    """Set up and parse command-line arguments.

    Returns:
        ArgumentParser instance with configured arguments and help text
    """
    epilog = [
        "Examples:",
        "  trash file1.txt",
        "  trash file1 file2 directory/",
        "  trash -r important_dir/",
        "  trash -v -r backup.tar.gz",
        "  trash -f old_nonexistent_file",
        "",
        "Note: Files are moved to ~/.trash for recovery.",
    ]
    parser = ArgumentParser(
        prog="trash",
        description="Move files and directories to a backup location (~/.trash)",
        epilog=("\n".join(epilog)),
        formatter_class=RawDescriptionHelpFormatter,
        add_help=True,
    )
    parser.add_argument(
        "-r",
        "--recursive",
        action="store_true",
        help="Required for directories (compress with tar)",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true", help="Show hashes for trashed items"
    )
    parser.add_argument(
        "-f", "--force", action="store_true", help="Ignore nonexistent files"
    )
    parser.add_argument(
        "files", nargs="*", type=Path, help="Files or directories to trash"
    )
    return parser


def _process_files(file_paths: list[Path], config: TrashConfig) -> bool:
    """Process multiple files by trashing them and recording metadata.

    Iterates over file paths, calls _process_file_path for each, and tracks
    overall success. Returns True if all files processed successfully, False
    if any errors occurred (unless force flag is set).

    Args:
        file_paths: List of paths to files or directories
        config: Trash configuration

    Returns:
        True if all files processed successfully, False if any errors occurred
    """
    success = True
    for file_path in file_paths:
        try:
            trash_path = TrashPath.create(file_path)
            if trash_path.is_symlink():
                metadata = config.trash_symlink(trash_path)
            elif trash_path.is_dir():
                metadata = config.trash_dir(trash_path)
            else:
                metadata = config.trash_file(trash_path)
            config.write_metadata(metadata)
            if config.verbose:
                print(
                    f"Trashed: {file_path} [hash: {metadata.hash}]",
                    file=sys.stderr,
                )
        except FileNotFoundError:
            if config.force:
                # force flag: silently skip nonexistent files
                continue
            print(
                f"Error trashing {file_path}: No such file or directory",
                file=sys.stderr,
            )
            success = False
        except (ValueError, RuntimeError) as e:
            print(f"Error trashing {file_path}: {e}", file=sys.stderr)
            success = False
    return success


EXIT_SUCCESS = 0
EXIT_FAILURE = 1


def main() -> int:
    """Main entry point: orchestrate trash operations with configuration.

    Parses command-line arguments, validates file arguments, builds TrashConfig,
    and processes each file. Exception handling is delegated to _process_files().
    """
    parser = _setup_parser()
    args = parser.parse_args()
    # Check if files provided
    if not args.files:
        print("Error: Missing file arguments", file=sys.stderr)
        parser.print_help(sys.stderr)
        return EXIT_FAILURE
    # Build TrashConfig once after args parse
    config = TrashConfig(
        verbose=args.verbose,
        force=args.force,
        recursive=args.recursive,
    )
    # Process each file
    if _process_files(args.files, config):
        return EXIT_SUCCESS
    else:
        return EXIT_FAILURE


if __name__ == "__main__":
    sys.exit(main())

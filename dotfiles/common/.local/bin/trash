#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import json
import os
import shutil
import sys
import time
from argparse import ArgumentParser, Namespace, RawDescriptionHelpFormatter
from dataclasses import dataclass
from dataclasses import replace as dataclass_replace
from datetime import datetime
from pathlib import Path


@dataclass
class TrashEvent:
    """Single event in trash-log.jsonl — immutable data container."""

    path: str
    timestamp: int  # Epoch when trashed (= filename in .trash/)
    restore: bool = False

    def to_dict(self) -> dict[str, str | int | bool]:
        """Convert to JSON-serializable dict for trash-log.jsonl."""
        return {
            "path": self.path,
            "timestamp": self.timestamp,
            "restore": self.restore,
        }

    @classmethod
    def from_dict(cls, d: dict[str, str | int | bool]) -> "TrashEvent":
        """Deserialize from JSON dict."""
        return cls(
            path=str(d["path"]),
            timestamp=int(d["timestamp"]),
            restore=bool(d.get("restore", False)),
        )


class TrashLog:
    """Manages trash-log.jsonl as append-only event log.

    Loads entire event history into memory at init for fast queries.
    Stores events as dict[str, list[TrashEvent]] keyed by path for O(1) lookup.
    Provides active_events(), make_restore_event(), get_trash_path(), execute_trash(),
    and append().
    """

    def __init__(self) -> None:
        """Initialize TrashLog; defaults to TRASH_DIR env or ~/.trash."""
        self._trash_dir = Path(os.getenv("TRASH_DIR", Path.home() / ".trash"))
        self._metadata_path = self._trash_dir / "trash-log.jsonl"
        self._events: dict[str, list[TrashEvent]] = {}
        self.load()

    def get_latest_event(self, path: Path) -> TrashEvent | None:
        """Get the latest TrashEvent for a given path, or None if no events exist."""
        events_for_path = self._events.get(str(path), [])
        if not events_for_path:
            return None
        # D-01: Use (timestamp, restore) tiebreaker so restore events (1) beat
        # trash events (0) when timestamps are equal.
        return max(events_for_path, key=lambda e: (e.timestamp, e.restore))

    def make_restore_event(self, path: Path) -> TrashEvent:
        """Create a restore TrashEvent for the latest trashable entry at path.

        Looks up the most recent non-restored event for path.
        Returns a new TrashEvent with restore=True and the same timestamp.

        Raises:
            ValueError: No trash entry found, or most recent entry is already restored.
        """
        latest = self.get_latest_event(path.absolute())
        if latest is None:
            raise ValueError(f"No trash entry found for {path}")
        if latest.restore:
            raise ValueError(
                f"No restorable entry found for {path}:"
                " most recent entry is already restored"
            )
        return dataclass_replace(latest, restore=True)

    def get_trash_path(self, event: TrashEvent) -> Path:
        """Return unique path in trash_dir for event; mutates event.timestamp.

        Side effect: event.timestamp is updated to the selected timestamp value.
        Callers must read event.timestamp after this call to get the final value
        (e.g., for verbose output).

        For trash events: increments timestamp until a free slot is found.
        For restore events: returns the path of the already-trashed item.
        """
        timestamp = event.timestamp or int(time.time())
        trash_path = self._trash_dir / str(timestamp)
        while not event.restore and os.path.lexists(trash_path):
            timestamp += 1
            trash_path = self._trash_dir / str(timestamp)
        event.timestamp = timestamp
        return trash_path

    def execute_trash(self, event: TrashEvent, recursive: bool) -> None:
        """Execute trash or restore operation based on event.restore flag.

        Takes a pre-built TrashEvent (created by caller or make_restore_event())
        and performs the actual file I/O.

        Args:
            event: TrashEvent controlling operation type via event.restore flag

        Raises:
            FileNotFoundError: Source path doesn't exist (trash) or trash item
                missing (restore)
            shutil.Error: File operation fails
        """
        if not event.restore:
            if not os.path.lexists(event.path):
                raise FileNotFoundError(f"No such file or directory: {event.path}")
            if Path.cwd().is_relative_to(Path(event.path).resolve()):
                raise ValueError(f"Cannot trash parent directory: {event.path}")
            if Path(event.path).is_dir() and not recursive:
                raise ValueError(
                    f"Cannot trash directory without -r flag: {event.path}"
                )
        elif os.path.lexists(event.path):
            print(
                f"trash: {event.path} exists; backing up to trash...",
                file=sys.stderr,
            )
            backup_event = TrashEvent(path=event.path, timestamp=0)
            self.execute_trash(backup_event, recursive)
        if event.restore:
            source_path = self.get_trash_path(event)
            if not os.path.lexists(source_path):
                raise FileNotFoundError(
                    f"Trash item missing (log/filesystem desync): {source_path}"
                )
            target_path = Path(event.path)
        else:
            source_path = Path(event.path)
            target_path = self.get_trash_path(event)
        target_path.parent.mkdir(parents=True, exist_ok=True)
        shutil.move(source_path, target_path)
        self.append(event)

    def load(self) -> None:
        """Read and parse trash-log.jsonl, rebuild in-memory event dict.

        Handles missing file, empty file gracefully.
        Tolerates a single truncated final line (crash-during-write pattern).
        Raises ValueError on malformed lines that are not at end-of-file.

        Note: Changes to _events must be persisted via append().
        """
        self._events = {}
        self._trash_dir.mkdir(parents=True, exist_ok=True)
        if not self._metadata_path.exists():
            return
        with open(self._metadata_path) as f:
            raw_lines = f.readlines()
        total_lines = len(raw_lines)
        for lineno, line in enumerate(raw_lines, 1):
            line = line.strip()
            if not line:
                continue
            try:
                entry_dict = json.loads(line)
                event = TrashEvent.from_dict(entry_dict)
                self._events.setdefault(event.path, []).append(event)
            except (json.JSONDecodeError, KeyError, ValueError) as e:
                # Tolerate truncated final line only (crash leaves no trailing newline).
                # A complete line ending with "\n" is not crash residue — always raise.
                if lineno == total_lines and not raw_lines[-1].endswith("\n"):
                    break
                raise ValueError(
                    f"Malformed metadata entry at line {lineno}: {e}"
                ) from e

    def active_events(self) -> list[TrashEvent]:
        """Return currently-trashed events (latest per path is not a restore event).

        Uses timestamp-based filtering (max timestamp per path), independent of
        append order. Each path's latest event is checked for restore=False.
        """
        result: list[TrashEvent] = []
        for path in self._events:
            # D-01: Use (timestamp, restore) tiebreaker so restore events (1) beat
            # trash events (0) when timestamps are equal.
            latest_event = self.get_latest_event(Path(path))
            if latest_event is None or latest_event.restore:
                continue
            result.append(latest_event)
        return result

    def append(self, event: TrashEvent) -> None:
        """Add event to memory and sync to disk immediately."""
        with open(self._metadata_path, "a") as f:
            json.dump(event.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")
            os.fsync(f.fileno())
        self._events.setdefault(event.path, []).append(event)


class TrashConfig(Namespace):
    """Configuration for trash operations — argparse Namespace subclass.

    Hides ArgumentParser as internal state. External callers use only:
    - TrashConfig.parse_args(args=None) -> TrashConfig
    - config.print_help()
    """

    verbose: bool
    force: bool
    recursive: bool
    files: list[Path]
    restore: bool
    show_list: bool

    @classmethod
    def _build_parser(cls) -> ArgumentParser:
        """Internal: construct and return ArgumentParser.

        Contains all parser configuration for the trash command.
        Must not be called directly from outside TrashConfig.
        """
        epilog = [
            "Examples:",
            "  trash file1.txt",
            "  trash file1 file2 directory/",
            "  trash -r important_dir/",
            "  trash -v -r backup.tar.gz",
            "  trash -f old_nonexistent_file",
            "  trash --restore /path/to/file",
            "  trash --list",
            "",
            "Note: Files are moved to ~/.trash for recovery.",
        ]
        parser = ArgumentParser(
            prog="trash",
            description="Safe deletion and recovery via backup location (~/.trash)",
            epilog=("\n".join(epilog)),
            formatter_class=RawDescriptionHelpFormatter,
            add_help=True,
        )
        parser.add_argument(
            "--restore",
            action="store_true",
            help="Restore file(s) from trash by their original path",
        )
        parser.add_argument(
            "--list",
            "-l",
            action="store_true",
            dest="show_list",
            help="List all items in trash",
        )
        parser.add_argument(
            "-r",
            "--recursive",
            action="store_true",
            help="Required for directories",
        )
        parser.add_argument(
            "-v",
            "--verbose",
            action="store_true",
            help="Show timestamps for trashed items",
        )
        parser.add_argument(
            "-f", "--force", action="store_true", help="Ignore nonexistent files"
        )
        parser.add_argument(
            "files",
            nargs="*",
            type=Path,
            help="Files or directories to trash (or paths to restore with --restore)",
        )
        return parser

    @classmethod
    def parse_args(cls, args: list[str] | None = None) -> "TrashConfig":
        """Parse CLI arguments into TrashConfig instance.

        Hides ArgumentParser internals. Returns populated TrashConfig.
        """
        parser = cls._build_parser()
        return parser.parse_args(args, namespace=cls())

    def print_help(self) -> None:
        """Print help text to stdout."""
        self._build_parser().print_help()


EXIT_SUCCESS = 0
EXIT_FAILURE = 1
_LIST_START_INDEX = 1  # 1-based display numbering for --list output


def list_items(trash_log: TrashLog) -> None:
    """Print trash-log.jsonl contents in human-readable format to stdout."""
    entries = trash_log.active_events()
    if not entries:
        return
    print(f"Files in trash ({len(entries)}):")
    for i, entry in enumerate(entries, _LIST_START_INDEX):
        print(f"  {i}. {entry.path}")
        dt_local = datetime.fromtimestamp(entry.timestamp).astimezone()
        ts_iso = dt_local.isoformat(timespec="seconds")
        print(f"     timestamp: {ts_iso}")


def main() -> int:
    """Main entry point: orchestrate trash, restore, or list operations.

    Uses make_restore_event() for restore operations (raises ValueError if not found).
    Catches ValueError alongside shutil.Error and OSError.
    """
    config = TrashConfig.parse_args()
    trash_log = TrashLog()
    success = EXIT_SUCCESS
    if config.show_list:
        list_items(trash_log)
        return EXIT_SUCCESS
    if not config.files:
        if config.restore:
            msg = "provide a path to restore or use --list"
        else:
            msg = "Missing file arguments"
        print(f"Error: {msg}", file=sys.stderr)
        config.print_help()
        return EXIT_FAILURE
    for path in config.files:
        try:
            if config.restore:
                event = trash_log.make_restore_event(path)
            else:
                event = TrashEvent(path=str(path.absolute()), timestamp=0)
            trash_log.execute_trash(event, config.recursive)
            if not config.verbose:
                continue
            if config.restore:
                print(
                    f"trash: restored {path} [timestamp: {event.timestamp}]",
                    file=sys.stderr,
                )
            else:
                print(
                    f"trash: trashed {path} [timestamp: {event.timestamp}]",
                    file=sys.stderr,
                )
        except (shutil.Error, OSError, ValueError) as e:
            if config.force:
                continue
            op = "restoring" if config.restore else "trashing"
            print(f"trash: error {op} {path}: {e}", file=sys.stderr)
            success = EXIT_FAILURE
    return success


if __name__ == "__main__":
    sys.exit(main())

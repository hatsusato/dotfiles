#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import sys
import argparse
import json
import os
from pathlib import Path
from datetime import datetime, timezone
from typing import Optional
import tempfile
import subprocess
import hashlib
import shutil

# Constants
DEFAULT_TRASH_DIR = Path.home() / ".trash"
EXIT_SUCCESS = 0
EXIT_FAILURE = 1


def _print_help() -> None:
    """Display usage, options, examples, and recovery note to stderr."""
    help_text = """\
Usage: trash [-r] [-v] [-f] [-h] FILE...

Options:
  -r, --recursive    Delete directories recursively (compress with tar)
  -v, --verbose      Show each deleted file and its hash
  -f, --force        Ignore nonexistent files and continue on error
  -h, --help         Display this help message

Examples:
  trash file1.txt
  trash file1 file2 directory/
  trash -r important_dir/
  trash -v -r backup.tar.gz
  trash -f old_nonexistent_file

Note: Files are moved to ~/.trash for recovery.
"""
    print(help_text, file=sys.stderr, end='')


def _hash_file(path: Path) -> str:
    """Compute SHA256 hash of file in 8KB chunks.

    Args:
        path: Path to file to hash

    Returns:
        Hexadecimal hash string (no filename)

    Raises:
        RuntimeError: If file cannot be read
    """
    sha256 = hashlib.sha256()
    try:
        with open(path, 'rb') as f:
            for chunk in iter(lambda: f.read(8192), b''):
                sha256.update(chunk)
        return sha256.hexdigest()
    except (FileNotFoundError, PermissionError, IOError) as e:
        raise RuntimeError(f"Failed to hash file: {e}")


def _tar_and_hash_dir(dir_path: Path, temp_dir: Path) -> tuple[str, Path]:
    """Create uncompressed tar archive of directory, then hash it.

    Args:
        dir_path: Path to directory to tar
        temp_dir: Temporary directory for tar file

    Returns:
        Tuple of (hash_value, tar_path)

    Raises:
        RuntimeError: If tar creation or hashing fails
    """
    # Create temporary tar file
    tar_file = tempfile.NamedTemporaryFile(suffix='.tar', dir=temp_dir, delete=False)
    tar_path = Path(tar_file.name)
    tar_file.close()

    try:
        # Create uncompressed tar (matches bash: tar -cf)
        subprocess.run(
            ['tar', '-cf', str(tar_path), '-C', str(dir_path.parent), dir_path.name],
            check=True,
            capture_output=True,
            text=False
        )

        # Hash the tar archive
        hash_value = _hash_file(tar_path)
        return hash_value, tar_path
    except subprocess.CalledProcessError as e:
        tar_path.unlink(missing_ok=True)
        raise RuntimeError(f"Failed to compress directory: {e}")
    except Exception as e:
        tar_path.unlink(missing_ok=True)
        raise


def _record_metadata(
    trash_dir: Path,
    hash_value: str,
    original_path: Path,
    is_directory: bool
) -> None:
    """Append metadata entry to metadata.jsonl (JSON Lines format).

    Args:
        trash_dir: Path to trash directory
        hash_value: SHA256 hash of file/archive
        original_path: Original absolute path (should be resolved)
        is_directory: True if this was a directory

    Raises:
        RuntimeError: If metadata cannot be written
    """
    # For metadata, store absolute path without following symlinks
    abs_path = original_path if original_path.is_absolute() else Path.cwd() / original_path
    metadata_entry = {
        "hash": hash_value,
        "path": str(abs_path),
        "type": "dir" if is_directory else "file",
        "date": datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S')
    }

    metadata_path = trash_dir / "metadata.jsonl"
    try:
        with open(metadata_path, 'a') as f:
            json.dump(metadata_entry, f, ensure_ascii=False, separators=(',', ':'))
            f.write('\n')
    except (IOError, PermissionError) as e:
        raise RuntimeError(f"Failed to record metadata: {e}")


def _trash_file(
    file_path: Path,
    trash_dir: Path,
    is_directory: bool,
    force: bool,
    verbose: bool
) -> bool:
    """Move a single file or directory to trash with metadata recording.

    Args:
        file_path: Path to file or directory
        trash_dir: Path to trash directory
        is_directory: True if file_path is a directory
        force: If True, silently ignore nonexistent files
        verbose: If True, print verbose output to stderr

    Returns:
        True on success, False on error
    """
    try:
        # Make path absolute WITHOUT following symlinks
        # (Path.resolve() follows symlinks, so we do it manually)
        if not file_path.is_absolute():
            file_path = Path.cwd() / file_path

        # Check if file exists (before checking symlink, in case symlink points to nonexistent)
        if not file_path.exists() and not file_path.is_symlink():
            if not force:
                print(f"Error trashing {file_path}: No such file or directory", file=sys.stderr)
                return False
            else:
                # Force flag: silently ignore nonexistent
                return True

        # Refuse to trash dangerous paths (use absolute path for comparison)
        abs_path = file_path.resolve() if file_path.exists() or not file_path.is_symlink() else file_path
        if abs_path == Path('/') or abs_path == Path.home() or abs_path == Path('.'):
            print(f"Error trashing {file_path}: Cannot trash system directory", file=sys.stderr)
            return False

        # Check directory without -r flag (not needed here, handled in main)
        # This check happens in main() before calling this function

        # Compute hash and prepare file for moving
        hash_value: str
        tar_path: Optional[Path] = None
        is_symlink = file_path.is_symlink()

        if is_symlink:
            # Symlink: read target and hash it as a regular file
            try:
                symlink_target = file_path.readlink()
                # Create temp file with symlink target path as content
                tmp_file = tempfile.NamedTemporaryFile(delete=False)
                tmp_path = Path(tmp_file.name)
                tmp_file.write(str(symlink_target).encode('utf-8'))
                tmp_file.close()

                hash_value = _hash_file(tmp_path)
                # We'll move tmp_path to trash (and delete the symlink separately)
                tar_path = tmp_path
            except Exception as e:
                print(f"Error trashing {file_path}: Failed to read symlink: {e}", file=sys.stderr)
                return False
        elif is_directory:
            # Directory: tar it first
            try:
                hash_value, tar_path = _tar_and_hash_dir(file_path, Path(tempfile.gettempdir()))
            except RuntimeError as e:
                print(f"Error trashing {file_path}: {e}", file=sys.stderr)
                return False
        else:
            # Regular file: hash directly
            try:
                hash_value = _hash_file(file_path)
            except RuntimeError as e:
                print(f"Error trashing {file_path}: {e}", file=sys.stderr)
                return False

        # Create TRASH_DIR if absent
        try:
            trash_dir.mkdir(parents=True, exist_ok=True)
        except (OSError, PermissionError) as e:
            print(f"Error trashing {file_path}: Failed to create trash directory: {e}", file=sys.stderr)
            if tar_path:
                tar_path.unlink(missing_ok=True)
            return False

        # Move to trash
        trash_path = trash_dir / hash_value
        try:
            if tar_path:
                # Moving a temporary file (symlink or tar)
                shutil.move(str(tar_path), str(trash_path))
            else:
                # Moving the original file (use shutil.move for cross-filesystem safety)
                shutil.move(str(file_path), str(trash_path))
        except (OSError, PermissionError) as e:
            print(f"Error trashing {file_path}: Failed to move to trash: {e}", file=sys.stderr)
            if tar_path:
                tar_path.unlink(missing_ok=True)
            return False

        # Remove original file if not already moved
        if is_symlink:
            # For symlinks, we moved a temp file to trash, but the original symlink is still here
            try:
                file_path.unlink()
            except Exception:
                pass  # Already removed
        elif is_directory:
            # For directories, we moved a tar to trash, but the original dir is still here
            try:
                shutil.rmtree(file_path)
            except Exception:
                pass  # Already removed by move or doesn't exist

        # Record metadata
        try:
            _record_metadata(trash_dir, hash_value, file_path, is_directory)
        except RuntimeError as e:
            print(f"Error trashing {file_path}: {e}", file=sys.stderr)
            return False

        # Verbose output
        if verbose:
            print(f"Trashed: {file_path} [hash: {hash_value}]", file=sys.stderr)

        return True

    except Exception as e:
        print(f"Error trashing {file_path}: {e}", file=sys.stderr)
        return False


def main() -> int:
    """Main entry point."""
    parser = argparse.ArgumentParser(
        prog='trash',
        description='Move files and directories to a backup location (~/.trash)',
        epilog='Backed-up items are stored in ~/.trash/ with metadata in metadata.jsonl',
        add_help=False  # Handle -h manually to match bash behavior
    )

    parser.add_argument(
        '-r', '--recursive',
        action='store_true',
        help='Required for directories (compress with tar)'
    )
    parser.add_argument(
        '-v', '--verbose',
        action='store_true',
        help='Show hashes for trashed items'
    )
    parser.add_argument(
        '-f', '--force',
        action='store_true',
        help='Ignore nonexistent files'
    )
    parser.add_argument(
        '-h', '--help',
        action='store_true',
        help='Display this help message'
    )
    parser.add_argument(
        'files',
        nargs='*',
        help='Files or directories to trash'
    )

    try:
        args = parser.parse_args()
    except SystemExit:
        # argparse calls sys.exit on error; we want to return a code instead
        return EXIT_FAILURE

    # Handle help flag
    if args.help:
        _print_help()
        return EXIT_SUCCESS

    # Check if files provided
    if not args.files:
        print("Error: Missing file arguments", file=sys.stderr)
        _print_help()
        return EXIT_FAILURE

    # Get trash directory from environment or use default
    trash_dir = Path(os.environ.get('TRASH_DIR', DEFAULT_TRASH_DIR))

    # Process each file
    had_error = False
    for file_arg in args.files:
        file_path = Path(file_arg)

        # Determine if this is a directory (check symlink first!)
        is_directory = False
        if file_path.is_symlink():
            # Symlinks are never treated as directories, even if they point to one
            is_directory = False
        elif file_path.is_dir():
            is_directory = True

        # Check directory without -r flag
        if is_directory and not args.recursive:
            print(f"Error trashing {file_path}: Cannot trash directory without -r flag", file=sys.stderr)
            had_error = True
            continue

        # Trash the file
        if not _trash_file(file_path, trash_dir, is_directory, args.force, args.verbose):
            had_error = True
        # Continue to next file regardless of error

    return EXIT_FAILURE if had_error else EXIT_SUCCESS


if __name__ == '__main__':
    sys.exit(main())

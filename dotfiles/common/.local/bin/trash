#!/usr/bin/env python3
"""trash — Safe file and directory deletion via backup location.

Moves files and directories to ~/.trash/ (configurable via TRASH_DIR environment
variable) and records metadata about each operation in JSON Lines format for recovery.
"""

import sys
import argparse
import json
import os
import uuid
from dataclasses import dataclass
from pathlib import Path
from datetime import datetime, timezone
from typing import Literal, Self
import subprocess
import hashlib
import shutil

# Constants
DEFAULT_TRASH_DIR = Path.home() / ".trash"
EXIT_SUCCESS = 0
EXIT_FAILURE = 1


@dataclass(frozen=True)
class TrashPath:
    """Immutable path validator and type detector.

    Encapsulates path normalization, existence checking, dangerous path
    detection, and type detection. All validation logic is centralized here.
    """

    path: Path
    item_type: Literal["file", "dir", "symlink"]

    @staticmethod
    def _determine_type(path: Path) -> Literal["file", "dir", "symlink"]:
        """Detect item type. Check is_symlink() BEFORE is_dir() (D-06 pitfall).

        CRITICAL: is_symlink() must be checked before is_dir() because is_dir()
        follows symlinks. A symlink-to-directory would be incorrectly detected as
        a directory if we check is_dir() first (D-06 pitfall).
        """
        if path.is_symlink():
            return "symlink"
        if path.is_dir():
            return "dir"
        return "file"

    @classmethod
    def from_path(cls, path: Path) -> "TrashPath":
        """Validate filesystem path for trasheability.

        Encapsulates path normalization, existence checking, dangerous path
        detection, and type detection. All validation logic copied from
        Metadata.from_path() to ensure compatibility.

        Args:
            path: Relative or absolute file path

        Returns:
            TrashPath instance with normalized path and detected type

        Raises:
            FileNotFoundError: Path does not exist and is not a symlink
            ValueError: Path is a dangerous system directory (/, home, .)
        """
        # Normalize path to absolute
        normalized = path if path.is_absolute() else Path.cwd() / path

        # Check existence (symlinks may point to nonexistent targets — check both)
        if not normalized.exists() and not normalized.is_symlink():
            raise FileNotFoundError(f"{path}: No such file or directory")

        # Detect dangerous paths: resolve if possible, use normalized if broken symlink
        try:
            resolved = normalized.resolve() if normalized.exists() else normalized
        except (OSError, RuntimeError):
            # Broken symlink or permission error — use normalized
            resolved = normalized

        if resolved in (Path("/"), Path.home(), Path(".")):
            raise ValueError(f"Cannot trash system directory: {path}")

        # Determine type using static method
        determined_type = cls._determine_type(normalized)

        return cls(path=normalized, item_type=determined_type)


def _hash_file(file_path: Path) -> str:
    """Compute SHA256 hash of file in 8KB chunks.

    Pure function for hashing files. Takes explicit path parameter,
    returns computed hash string. No state mutation.

    Args:
        file_path: Path to file to hash

    Returns:
        SHA256 hexdigest as string

    Raises:
        RuntimeError: If file cannot be read
    """
    sha256 = hashlib.sha256()
    try:
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                sha256.update(chunk)
        return sha256.hexdigest()
    except (FileNotFoundError, PermissionError, IOError) as e:
        raise RuntimeError(f"Failed to hash file: {e}") from e


def _tar_and_hash_dir(path: Path, trash_dir: Path) -> tuple[str, Path]:
    """Create tar of directory contents, hash it, return (hash, temp_path).

    Pure function for tarring and hashing directories. Uses trash_dir as temp
    location (D-08: same filesystem, atomic rename). Tar structure: -C dir_path .
    so tar contains ./file1, ./subdir/file2 etc. Original path is preserved in
    metadata — tar only needs contents (D-09).

    Args:
        path: Directory path to tar
        trash_dir: Trash directory (used as temp location)

    Returns:
        Tuple of (hash_value, temp_tar_path)

    Raises:
        RuntimeError: If tar or hashing fails
    """
    temp_tar = trash_dir / f"tmp_{uuid.uuid4().hex[:8]}.tar"
    try:
        subprocess.run(
            ["tar", "-cf", str(temp_tar), "-C", str(path), "."],
            check=True,
            capture_output=True,
            text=False,
        )
        # Hash the tar file
        hash_value = _hash_file(temp_tar)
        return hash_value, temp_tar
    except subprocess.CalledProcessError as e:
        temp_tar.unlink(missing_ok=True)
        raise RuntimeError(f"Failed to tar directory: {e}") from e
    except RuntimeError:
        temp_tar.unlink(missing_ok=True)
        raise


@dataclass
class TrashConfig:
    """Immutable configuration for trash operations."""

    trash_dir: Path
    verbose: bool = False
    force: bool = False
    recursive: bool = False


def trash_symlink(path: Path, config: TrashConfig) -> "Metadata":
    """Move symlink directly to trash; preserve inode and target path.

    Hash is computed from symlink target string. Returns Metadata with hash set.

    Args:
        path: Path to symlink
        config: Trash configuration

    Returns:
        Metadata with hash and type set

    Raises:
        RuntimeError: If symlink cannot be trashed
    """
    try:
        symlink_target = path.readlink()
        hash_value = hashlib.sha256(str(symlink_target).encode()).hexdigest()

        trash_path = config.trash_dir / hash_value
        config.trash_dir.mkdir(parents=True, exist_ok=True)
        shutil.move(str(path), str(trash_path))

        return Metadata(
            path=path,
            hash=hash_value,
            type="symlink",
            date=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S"),
        )
    except (OSError, RuntimeError) as e:
        raise RuntimeError(f"Failed to trash {path}: {e}") from e


def trash_file(path: Path, config: TrashConfig) -> "Metadata":
    """Hash file and move to trash_dir/{hash}.

    Returns Metadata with hash set.

    Args:
        path: Path to file
        config: Trash configuration

    Returns:
        Metadata with hash and type set

    Raises:
        RuntimeError: If file cannot be trashed
    """
    try:
        hash_value = _hash_file(path)

        trash_path = config.trash_dir / hash_value
        config.trash_dir.mkdir(parents=True, exist_ok=True)
        shutil.move(str(path), str(trash_path))

        return Metadata(
            path=path,
            hash=hash_value,
            type="file",
            date=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S"),
        )
    except (OSError, RuntimeError) as e:
        raise RuntimeError(f"Failed to trash {path}: {e}") from e


def trash_dir(path: Path, config: TrashConfig) -> "Metadata":
    """Tar directory contents, hash archive, move to trash, record metadata.

    Returns Metadata with hash set.

    Args:
        path: Path to directory
        config: Trash configuration

    Returns:
        Metadata with hash and type set

    Raises:
        RuntimeError: If directory cannot be trashed
    """
    try:
        hash_value, tar_path = _tar_and_hash_dir(path, config.trash_dir)

        final_path = config.trash_dir / hash_value
        tar_path.rename(final_path)
        shutil.rmtree(path)

        return Metadata(
            path=path,
            hash=hash_value,
            type="dir",
            date=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S"),
        )
    except (OSError, subprocess.CalledProcessError, RuntimeError) as e:
        raise RuntimeError(f"Failed to trash {path}: {e}") from e


class Metadata:
    """Record of a trashed item: hash, original path, type, date.

    Pure data container — stores validated path, hash, type, and date.
    Metadata is created via from_path() classmethod for validation and
    normalization. Hash computation is deferred to TrashItem.trash() methods,
    which set metadata.hash after determining appropriate hash type per subclass.
    """

    def __init__(
        self,
        path: Path,
        hash: str = "",
        type: Literal["file", "dir", "symlink"] = "file",
        date: str = "",
    ) -> None:
        self.path = path
        self.hash = hash
        self.type = type
        self.date = date

    def to_dict(self) -> dict[str, str | None]:
        """Convert to JSON-serializable dict."""
        return {
            "hash": self.hash,
            "path": str(self.path),
            "type": self.type,
            "date": self.date,
        }

    @classmethod
    def from_dict(cls, d: dict[str, str]) -> Self:
        """Deserialize from JSON dict."""
        m = cls(
            path=Path(d["path"]),
            hash=d["hash"],
            type=d["type"],  # type: ignore[arg-type]
        )
        m.date = d["date"]
        return m

    @classmethod
    def from_path(cls, path: Path) -> Self:
        """Validate filesystem path for trasheability (normalization, type detection, date computation).

        Encapsulates path normalization, existence checking, dangerous path
        detection, type detection, and date computation. Hash is deferred to
        TrashItem subclasses during trash(). Returns Metadata with normalized
        path, type, and date set; hash is empty string (to be computed by trash()).

        Args:
            path: Relative or absolute file path

        Returns:
            Metadata instance with normalized path, type, and date set; hash=""

        Raises:
            FileNotFoundError: Path does not exist and is not a symlink
            ValueError: Path is a dangerous system directory (/, home, .)
        """
        # Normalize path to absolute
        normalized = path if path.is_absolute() else Path.cwd() / path

        # Check existence (symlinks may point to nonexistent targets — check both)
        if not normalized.exists() and not normalized.is_symlink():
            raise FileNotFoundError(f"{path}: No such file or directory")

        # Detect dangerous paths: resolve if possible, use normalized if broken symlink
        try:
            resolved = normalized.resolve() if normalized.exists() else normalized
        except (OSError, RuntimeError):
            # Broken symlink or permission error — use normalized
            resolved = normalized

        if resolved in (Path("/"), Path.home(), Path(".")):
            raise ValueError(f"Cannot trash system directory: {path}")

        # Determine type using static method
        type_str = cls._determine_type_static(normalized)
        # Type guard: cast static result to Literal type
        determined_type: Literal["file", "dir", "symlink"] = type_str  # type: ignore[assignment]

        # Compute date
        computed_date = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S")

        # Return Metadata with normalized path, determined type, and computed date; hash is empty
        return cls(normalized, hash="", type=determined_type, date=computed_date)

    @staticmethod
    def _determine_type_static(path: Path) -> str:
        """Detect item type. Check is_symlink() BEFORE is_dir() (D-06 pitfall).

        This static version is used by from_path() during validation.
        """
        if path.is_symlink():
            return "symlink"
        if path.is_dir():
            return "dir"
        return "file"

    def write_to_jsonl(self, metadata_path: Path) -> None:
        """Append this metadata entry to metadata.jsonl in JSON Lines format."""
        metadata_path.parent.mkdir(parents=True, exist_ok=True)
        with open(metadata_path, "a") as f:
            json.dump(self.to_dict(), f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")


def main() -> int:
    """Main entry point: orchestrate trash operations with configuration.

    Validates file arguments, builds TrashConfig, and delegates to TrashItem.factory()
    and trash() for each file. Exception handling is consolidated to three specific
    exception types: FileNotFoundError (missing file), ValueError (dangerous path),
    and RuntimeError (operation failure).
    """
    parser = argparse.ArgumentParser(
        prog="trash",
        description="Move files and directories to a backup location (~/.trash)",
        epilog=(
            "Examples:\n"
            "  trash file1.txt\n"
            "  trash file1 file2 directory/\n"
            "  trash -r important_dir/\n"
            "  trash -v -r backup.tar.gz\n"
            "  trash -f old_nonexistent_file\n"
            "\n"
            "Note: Files are moved to ~/.trash for recovery."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=True,
    )

    parser.add_argument(
        "-r",
        "--recursive",
        action="store_true",
        help="Required for directories (compress with tar)",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true", help="Show hashes for trashed items"
    )
    parser.add_argument(
        "-f", "--force", action="store_true", help="Ignore nonexistent files"
    )
    parser.add_argument("files", nargs="*", help="Files or directories to trash")

    args = parser.parse_args()

    # Check if files provided
    if not args.files:
        print("Error: Missing file arguments", file=sys.stderr)
        parser.print_help(sys.stderr)
        return EXIT_FAILURE

    # Build TrashConfig once after args parse
    trash_dir_path = Path(os.environ.get("TRASH_DIR", DEFAULT_TRASH_DIR))
    config = TrashConfig(
        trash_dir=trash_dir_path,
        verbose=args.verbose,
        force=args.force,
        recursive=args.recursive,
    )

    # Process each file
    had_error = False
    for file_arg in args.files:
        try:
            file_path = Path(file_arg)
            # Validate path and detect type
            trash_path = TrashPath.from_path(file_path)

            # Check -r guard (permission-aware guard, not validation)
            if trash_path.item_type == "dir" and not config.recursive:
                print(
                    f"Error trashing {file_path}: Cannot trash directory without -r flag",
                    file=sys.stderr,
                )
                had_error = True
                continue

            # Dispatch to appropriate function
            if trash_path.item_type == "symlink":
                metadata = trash_symlink(file_path, config)
            elif trash_path.item_type == "dir":
                metadata = trash_dir(file_path, config)
            else:
                metadata = trash_file(file_path, config)

            # Record metadata (extracted from individual trash_* functions)
            metadata.write_to_jsonl(config.trash_dir / "metadata.jsonl")

            if config.verbose:
                print(
                    f"Trashed: {file_path} [hash: {metadata.hash}]",
                    file=sys.stderr,
                )

        except FileNotFoundError:
            if not config.force:
                print(
                    f"Error trashing {file_arg}: No such file or directory",
                    file=sys.stderr,
                )
                had_error = True
        except ValueError as e:
            print(f"Error trashing {file_arg}: {e}", file=sys.stderr)
            had_error = True
        except RuntimeError as e:
            print(f"Error trashing {file_arg}: {e}", file=sys.stderr)
            had_error = True

    return EXIT_FAILURE if had_error else EXIT_SUCCESS


if __name__ == "__main__":
    sys.exit(main())
